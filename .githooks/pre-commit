#!/usr/bin/env bash
set -euo pipefail

# Only check staged .cs files
mapfile -t STAGED_CS < <(git diff --cached --name-only --diff-filter=ACM -- '*.cs' 2>/dev/null || true)

if [ "${#STAGED_CS[@]}" -gt 0 ]; then
  echo "Running format check on staged C# files..."
  INCLUDE_ARGS=()
  for f in "${STAGED_CS[@]}"; do
    INCLUDE_ARGS+=(--include "$f")
  done
  FORMAT_OUTPUT=$(dotnet format --verify-no-changes "${INCLUDE_ARGS[@]}" 2>&1) || {
    echo "ERROR: Code formatting violations detected."
    echo "$FORMAT_OUTPUT"
    echo "Run 'dotnet format' to fix."
    exit 1
  }
fi

# Secret scanning on all staged files
mapfile -t STAGED_ALL < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ "${#STAGED_ALL[@]}" -gt 0 ]; then
  DIFF=$(git diff --cached -- "${STAGED_ALL[@]}")
  # Patterns aligned with CI scanner
  # Password pattern excludes comment lines (// or #) and targets connection-string-style assignments
  COMBINED_PATTERN='AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z\-_]{35}|-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----|(?<!//\s)(?<!#\s)Password\s*=\s*[^;"\x27]{8,}|api[_-]?key\s*[:=]\s*["\x27][A-Za-z0-9\-_]{20,}|secret[_-]?key\s*[:=]\s*["\x27][A-Za-z0-9\-_]{20,}'
  # Known false positives: CI/test passwords, placeholder values
  ALLOWLIST='Password\s*=\s*"?[A-Za-z]+@[0-9]+!?"?|Password=Unused@[0-9]+|example\.com|placeholder'
  MATCHES=$(printf '%s\n' "$DIFF" | grep -Pi "$COMBINED_PATTERN" | grep -Piv "$ALLOWLIST" || true)
  if [ -n "$MATCHES" ]; then
    echo "ERROR: Potential secrets detected in staged changes:"
    printf '%s\n' "$MATCHES"
    exit 1
  fi
fi

echo "Pre-commit checks passed."
