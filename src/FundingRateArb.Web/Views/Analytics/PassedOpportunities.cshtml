@model FundingRateArb.Web.ViewModels.PassedOpportunitiesViewModel

@{
    ViewData["Title"] = "Passed Opportunities";
}

<h2>Passed Opportunities</h2>
<p class="text-muted">Snapshot of every detected opportunity per bot cycle, showing which were opened and why others were skipped.</p>

<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label">Lookback</label>
        <select name="days" class="form-select form-select-sm">
            @if (Model.Days == 1) { <option value="1" selected>Last 24h</option> } else { <option value="1">Last 24h</option> }
            @if (Model.Days == 3) { <option value="3" selected>Last 3 days</option> } else { <option value="3">Last 3 days</option> }
            @if (Model.Days == 7) { <option value="7" selected>Last 7 days</option> } else { <option value="7">Last 7 days</option> }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary">Filter</button>
    </div>
</form>

@if (!Model.Snapshots.Any())
{
    <div class="alert alert-info">No opportunity snapshots found for the selected period.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-sm">
            <thead class="table-dark">
                <tr>
                    <th>Time (UTC)</th>
                    <th>Asset</th>
                    <th>Long</th>
                    <th>Short</th>
                    <th class="text-end">Spread/hr</th>
                    <th class="text-end">Net Yield/hr</th>
                    <th class="text-end">Long Vol 24h</th>
                    <th class="text-end">Short Vol 24h</th>
                    <th>Opened?</th>
                    <th>Skip Reason</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Snapshots)
                {
                    var rowClass = s.WasOpened ? "table-success" : "";
                    <tr class="@rowClass">
                        <td>@s.RecordedAt.ToString("MM-dd HH:mm")</td>
                        <td>@(s.Asset?.Symbol ?? $"#{s.AssetId}")</td>
                        <td>@(s.LongExchange?.Name ?? $"#{s.LongExchangeId}")</td>
                        <td>@(s.ShortExchange?.Name ?? $"#{s.ShortExchangeId}")</td>
                        <td class="text-end">@((s.SpreadPerHour * 100).ToString("F4"))%</td>
                        <td class="text-end">@((s.NetYieldPerHour * 100).ToString("F4"))%</td>
                        <td class="text-end">@s.LongVolume24h.ToString("N0")</td>
                        <td class="text-end">@s.ShortVolume24h.ToString("N0")</td>
                        <td>
                            @if (s.WasOpened)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(s.SkipReason))
                            {
                                var badgeClass = s.SkipReason switch
                                {
                                    "capital_exhausted" => "bg-danger",
                                    "cooldown" => "bg-warning text-dark",
                                    "active_position" => "bg-info text-dark",
                                    "below_threshold" => "bg-secondary",
                                    "max_positions" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                                <span class="badge @badgeClass">@s.SkipReason.Replace("_", " ")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination pagination-sm">
            @if (Model.Skip > 0)
            {
                var prevSkip = Math.Max(0, Model.Skip - Model.Take);
                <li class="page-item">
                    <a class="page-link" href="?days=@Model.Days&skip=@prevSkip&take=@Model.Take">Previous</a>
                </li>
            }
            @if (Model.HasMore)
            {
                var nextSkip = Model.Skip + Model.Take;
                <li class="page-item">
                    <a class="page-link" href="?days=@Model.Days&skip=@nextSkip&take=@Model.Take">Next</a>
                </li>
            }
        </ul>
    </nav>
}
