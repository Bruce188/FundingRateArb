@model FundingRateArb.Web.ViewModels.RateAnalyticsViewModel

@{
    ViewData["Title"] = "Rate Analytics";
}

<h4 class="mb-3">Rate Analytics</h4>

<div class="row mb-3">
    <div class="col-md-8">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label">Asset</label>
                <select name="assetId" class="form-select form-select-sm" id="asset-selector">
                    <option value="">-- Select Asset --</option>
                    @foreach (var asset in Model.AvailableAssets)
                    {
                        if (Model.SelectedAssetId == asset.Id)
                        {
                            <option value="@asset.Id" selected>@asset.Symbol</option>
                        }
                        else
                        {
                            <option value="@asset.Id">@asset.Symbol</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">Period</label>
                <select name="days" class="form-select form-select-sm" id="days-selector">
                    @foreach (var d in new[] { 1, 3, 7, 14, 30 })
                    {
                        if (Model.SelectedDays == d)
                        {
                            <option value="@d" selected>@d day@(d > 1 ? "s" : "")</option>
                        }
                        else
                        {
                            <option value="@d">@d day@(d > 1 ? "s" : "")</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Load</button>
            </div>
        </form>
    </div>
    <div class="col-md-4 text-end">
        @if (Model.SelectedAssetId.HasValue)
        {
            <a asp-action="Correlation" asp-route-assetId="@Model.SelectedAssetId" asp-route-days="@Model.SelectedDays"
               class="btn btn-sm btn-outline-secondary me-1">
                Correlation Matrix
            </a>
        }
    </div>
</div>

@if (Model.SelectedAssetId.HasValue && Model.Trends.Count > 0)
{
    <div class="row mb-4">
        @foreach (var trend in Model.Trends)
        {
            <div class="col-md-4 mb-2">
                <div class="card bg-dark text-white">
                    <div class="card-body py-2">
                        <small class="text-muted">@trend.ExchangeName</small>
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Current: @trend.CurrentRate.ToString("F6")/hr</span>
                            <span class="badge @(trend.TrendDirection == "rising" ? "bg-success" : trend.TrendDirection == "falling" ? "bg-danger" : "bg-secondary")">
                                @(trend.TrendDirection == "rising" ? "^" : trend.TrendDirection == "falling" ? "v" : "-") @trend.TrendDirection
                            </span>
                        </div>
                        <small>@(Model.SelectedDays)d avg: @trend.AvgPeriod.ToString("F6") | 24h avg: @trend.Avg24h.ToString("F6")</small>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card bg-dark mb-4">
        <div class="card-header text-white">Rate Trend Chart</div>
        <div class="card-body">
            <canvas id="rateTrendChart" height="100"></canvas>
        </div>
    </div>

    <div class="card bg-dark mb-4">
        <div class="card-header text-white">Time-of-Day Pattern</div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-auto">
                    <select id="tod-exchange-selector" class="form-select form-select-sm">
                        @foreach (var trend in Model.Trends)
                        {
                            <option value="@trend.ExchangeId">@trend.ExchangeName</option>
                        }
                    </select>
                </div>
            </div>
            <canvas id="todChart" height="80"></canvas>
        </div>
    </div>
}
else if (Model.SelectedAssetId.HasValue)
{
    <div class="alert alert-info">No rate data available for the selected asset and period.</div>
}

<div class="card bg-dark mb-4" id="zscore-alerts-card" style="display:none;">
    <div class="card-header text-white">Z-Score Alerts (|Z| > 2.0)</div>
    <div class="card-body p-0">
        <table class="table table-dark table-sm mb-0">
            <thead>
                <tr>
                    <th>Asset</th>
                    <th>Exchange</th>
                    <th>Current Rate</th>
                    <th>7d Mean</th>
                    <th>StdDev</th>
                    <th>Z-Score</th>
                </tr>
            </thead>
            <tbody id="zscore-alerts-body">
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"
            integrity="sha384-jb8JQMbMoBUzgWatfe6COACi2ljcDdZQ2OxczGA3bGNeWe+6DChMTBJemed7ZnvJ"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"
            integrity="sha384-cVMg8E3QFwTvGCDuK+ET4PD341jF3W8nO1auiXfuZNQkzbUUiBGLsIQUE+b1mxws"
            crossorigin="anonymous"></script>
    @* F6: Trend data loaded via AJAX from RateTrendData endpoint instead of inline JSON *@
    <div id="rate-analytics-config"
         data-asset-id="@(Model.SelectedAssetId?.ToString() ?? "")"
         data-days="@Model.SelectedDays"
         style="display:none;"></div>
    <script type="application/json" id="exchange-options-json">@Json.Serialize(Model.Trends.Select(t => new { t.ExchangeId, t.ExchangeName }))</script>
    <script src="~/js/rate-analytics.js" asp-append-version="true"></script>
    <script src="~/js/analytics.js" asp-append-version="true"></script>
}
