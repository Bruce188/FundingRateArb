@model FundingRateArb.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    bool IsVolumeConstrained(FundingRateArb.Application.DTOs.ArbitrageOpportunityDto opp)
    {
        if (Model.VolumeFraction <= 0) return false;
        var minVol = Math.Min(opp.LongVolume24h, opp.ShortVolume24h);
        return minVol * Model.VolumeFraction < Model.NotionalPerLeg;
    }

    // B1: Dynamic decimal formatting for small prices (server-side equivalent)
    string FormatPrice(decimal price)
    {
        if (price == 0) return "$0.00";
        if (price >= 1) return "$" + price.ToString("F2");
        if (price >= 0.01m) return "$" + price.ToString("F4");
        // For very small prices, show 4 significant digits
        var str = price.ToString("G4");
        return "$" + str;
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center">
        <h1 class="h3 mb-0">Dashboard</h1>
        @if (Model.IsAuthenticated)
        {
            var headingBadgeColor = Model.OperatingState switch
            {
                "Stopped" => "secondary",
                "Armed" => "info",
                "Trading" => "success",
                "Paused" => "warning",
                _ => "dark"
            };
            <span id="heading-bot-state" class="badge bg-@headingBadgeColor ms-2">@Model.OperatingState</span>
        }
    </div>
    @if (User.IsInRole("Admin"))
    {
        @Html.AntiForgeryToken()
        <button id="retry-now-btn" class="btn btn-warning btn-sm ms-2">Retry Now</button>
    }
</div>

@* Degraded-mode banner — shown when SignalEngine reports a transient DB outage. *@
@if (!Model.DatabaseAvailable)
{
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-exclamation-triangle me-2 flex-shrink-0" viewBox="0 0 16 16">
            <path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.15.15 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.2.2 0 0 1-.054.06.1.1 0 0 1-.066.017H1.146a.1.1 0 0 1-.066-.017.2.2 0 0 1-.054-.06.18.18 0 0 1 .002-.183L7.884 2.073a.15.15 0 0 1 .054-.057m1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z"/>
            <path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
        </svg>
        <div class="flex-grow-1">
            <strong>Data source unavailable.</strong> Some opportunities may be missing. Retrying automatically.
        </div>
    </div>
}

@if (!Model.IsAuthenticated)
{
    <div class="alert alert-primary d-flex align-items-center mb-4" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-person-lock me-2 flex-shrink-0" viewBox="0 0 16 16">
            <path d="M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0M8 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m0 5.996V14H3s-1 0-1-1 1-4 6-4q.564 0 1.077.07M9.5 12.5a.5.5 0 0 0-1 0V14a.5.5 0 0 0 1 0zM11 12a2 2 0 0 0-2 2v.5c0 .28.22.5.5.5h3a.5.5 0 0 0 .5-.5V14a2 2 0 0 0-2-2"/>
        </svg>
        <div class="flex-grow-1">
            <strong>Welcome!</strong> Sign in to enable trading, track your positions, and customize your bot settings.
        </div>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-sm ms-3">Sign Up</a>
    </div>
}

@if (Model.IsAuthenticated)
{
    <div class="d-flex align-items-center gap-2 mb-2 small text-muted">
        <span>Last update: <span id="last-update-time">--:--:--</span></span>
        <span id="stale-indicator" class="badge bg-warning text-dark" style="display:none">Stale</span>
    </div>
}

<!-- KPI Cards -->
<div class="row mb-4">
    @if (Model.IsAuthenticated)
    {
        <!-- Bot Status -->
        <div class="col-sm-6 col-xl-3 mb-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Bot Status</p>
                            @{
                                var stateColor = Model.OperatingState switch
                                {
                                    "Stopped" => "bg-danger",
                                    "Paused" => "bg-warning",
                                    "Armed" => "bg-primary",
                                    "Trading" => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span id="bot-status" class="badge @stateColor fs-6">
                                @Model.OperatingState.ToUpperInvariant()
                            </span>
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="mt-2 d-flex gap-1">
                                    <form asp-area="Admin" asp-controller="BotConfig" asp-action="SetState" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="newState" value="Armed" />
                                        <button type="submit" class="btn btn-outline-primary btn-sm py-0 px-2"
                                                @(Model.OperatingState is "Armed" or "Trading" ? "disabled" : "")>Arm</button>
                                    </form>
                                    <form asp-area="Admin" asp-controller="BotConfig" asp-action="SetState" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="newState" value="Stopped" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-2"
                                                @(Model.OperatingState == "Stopped" ? "disabled" : "")>Disarm</button>
                                    </form>
                                </div>
                            }
                        </div>
                        <div class="text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-robot" viewBox="0 0 16 16">
                                <path d="M6 12.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3a.5.5 0 0 1-.5-.5M3 8.062C3 6.76 4.235 5.765 5.53 5.886a26.6 26.6 0 0 0 4.94 0C11.765 5.765 13 6.76 13 8.062v1.157a.93.93 0 0 1-.765.935c-.845.147-2.34.346-4.235.346s-3.39-.2-4.235-.346A.93.93 0 0 1 3 9.219zm4.542-.827a.25.25 0 0 0-.217.068l-.92.9a25 25 0 0 1-1.871-.183.25.25 0 0 0-.068.495c.55.076 1.232.149 2.02.193a.25.25 0 0 0 .189-.071l.754-.736.847 1.71a.25.25 0 0 0 .404.062l.932-.97a25 25 0 0 0 1.922-.188.25.25 0 0 0-.068-.495c-.538.074-1.232.149-2.012.196a.25.25 0 0 0-.18.083l-.67.696-.727-1.466a.25.25 0 0 0-.186-.138"/>
                                <path d="M6.5 2h3A1.5 1.5 0 0 1 11 3.5V4h-1v-.5a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5V4H5v-.5A1.5 1.5 0 0 1 6.5 2M3 4.5A1.5 1.5 0 0 1 4.5 3h7A1.5 1.5 0 0 1 13 4.5v8A1.5 1.5 0 0 1 11.5 14h-7A1.5 1.5 0 0 1 3 12.5z"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Open Positions -->
        <div class="col-sm-6 col-xl-3 mb-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Open Positions</p>
                            <h4 class="mb-0"><span id="open-positions">@Model.OpenPositionCount</span></h4>
                            <small class="text-muted">
                                <span id="opening-positions">@Model.OpeningPositionCount</span> opening
                                <span id="needs-attention-badge" class="@(Model.NeedsAttentionCount > 0 ? "text-warning" : "text-success")">
                                    | <span id="needs-attention">@Model.NeedsAttentionCount</span> needs attention
                                </span>
                            </small>
                        </div>
                        <div class="text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-bar-chart" viewBox="0 0 16 16">
                                <path d="M4 11H2v3h2zm5-4H7v7h2zm5-5v12h-2V2zm-2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM6 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1zm-5 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1z"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total PnL -->
        <div class="col-sm-6 col-xl-3 mb-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Total PnL (est.)</p>
                            <h4 class="mb-0 @(Model.TotalPnl >= 0 ? "text-success" : "text-danger")">
                                $<span id="total-pnl">@Model.TotalPnl.ToString("F4")</span>
                            </h4>
                        </div>
                        <div class="text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-currency-dollar" viewBox="0 0 16 16">
                                <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718zm3.391-3.836c-1.043-.263-1.6-.825-1.6-1.616 0-.944.704-1.641 1.8-1.828v3.495l-.2-.051zm1.591 1.872c1.287.323 1.852.859 1.852 1.769 0 1.097-.826 1.828-2.2 1.939V8.73z"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Realized PnL (closed positions, phantom-fee rows excluded) -->
        <div class="col-sm-6 col-xl-3 mb-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Realized PnL</p>
                            <h4 class="mb-0 @(Model.TotalRealizedPnl >= 0 ? "text-success" : "text-danger")">
                                $@Model.TotalRealizedPnl.ToString("F4")
                            </h4>
                            <p class="text-muted" style="font-size:0.7rem;margin-top:2px;">Backfill-flagged rows excluded</p>
                        </div>
                        <div class="text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-check2-circle" viewBox="0 0 16 16">
                                <path d="M2.5 8a5.5 5.5 0 0 1 8.25-4.764.5.5 0 0 0 .5-.866A6.5 6.5 0 1 0 14.5 8a.5.5 0 0 0-1 0 5.5 5.5 0 1 1-11 0"/>
                                <path d="M15.354 3.354a.5.5 0 0 0-.708-.708L8 9.293 5.354 6.646a.5.5 0 1 0-.708.708l3 3a.5.5 0 0 0 .708 0z"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Best Spread -->
    <div class="col-sm-6 col-xl-3 mb-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-1">Best Spread/hr</p>
                        <h4 class="mb-0 text-info">
                            <span id="best-spread">@(Model.BestSpread > 0 ? (Model.BestSpread * 100).ToString("F4") + "%" : "N/A")</span>
                        </h4>
                    </div>
                    <div class="text-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-arrow-left-right" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M1 11.5a.5.5 0 0 0 .5.5h11.793l-3.147 3.146a.5.5 0 0 0 .708.708l4-4a.5.5 0 0 0 0-.708l-4-4a.5.5 0 0 0-.708.708L13.293 11H1.5a.5.5 0 0 0-.5.5m14-7a.5.5 0 0 1-.5.5H2.707l3.147 3.146a.5.5 0 1 1-.708.708l-4-4a.5.5 0 0 1 0-.708l4-4a.5.5 0 1 1 .708.708L2.707 4H14.5a.5.5 0 0 1 .5.5"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.IsAuthenticated)
{
    <!-- Exchange Balances (always visible, server-rendered initial data) -->
    <div class="row mb-3" id="exchange-balances-row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body py-2 px-3">
                    <div class="d-flex align-items-center">
                        <span class="text-muted small me-3">Balances:</span>
                        <div id="exchange-balances" class="d-flex flex-wrap gap-3 small">
                            @if (Model.InitialBalances is not null && Model.InitialBalances.Balances is not null)
                            {
                                @foreach (var b in Model.InitialBalances.Balances)
                                {
                                    <span class="exchange-balance" data-exchange="@b.ExchangeName">
                                        <strong>@b.ExchangeName:</strong> @b.AvailableUsdc.ToString("F2") USDC
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Balances: loading...</span>
                            }
                        </div>
                        <span class="text-muted small ms-auto" id="balance-total">
                            @if (Model.InitialBalances is not null)
                            {
                                <text>Total: @Model.InitialBalances.TotalAvailableUsdc.ToString("F2") USDC</text>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- B4: Persistent status explanation area -->
    <div class="row mb-3">
        <div class="col-12">
            <div id="status-explanation" class="alert alert-info mb-0 py-2 px-3 small" style="display:none;"></div>
        </div>
    </div>
}

@if (Model.Diagnostics is not null)
{
    var d = Model.Diagnostics;
    <div class="row mb-2">
        <div class="col-12">
            <small class="text-muted">
                Pipeline: @d.TotalRatesLoaded rates loaded | @d.RatesAfterStalenessFilter fresh | @d.TotalPairsEvaluated pairs evaluated | @d.PairsPassing passing
            </small>
        </div>
    </div>
}

<!-- Opportunities Table -->
<div class="row mb-4">
    <div class="col-12">
        <div id="circuit-breaker-status"></div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Arbitrage Opportunities</h5>
                <span class="badge bg-primary">@Model.Opportunities.Count found</span>
            </div>
            <div class="card-body p-0">
                @* Mobile card view (< 576px) *@
                <div id="opportunities-cards" class="d-sm-none p-2">
                    @if (Model.Opportunities.Count == 0)
                    {
                        <p class="text-muted text-center py-3 mb-0">No opportunities detected.</p>
                    }
                    else
                    {
                        @foreach (var opp in Model.Opportunities)
                        {
                            var apyBadge = opp.AnnualizedYield > 0.50m ? "bg-success" : opp.AnnualizedYield >= 0.20m ? "bg-warning text-dark" : "bg-secondary";
                            <div class="card mb-2 mobile-card">
                                <div class="card-body p-2">
                                    <div class="d-flex justify-content-between">
                                        <strong>@opp.AssetSymbol</strong>
                                        <span class="badge @apyBadge">@((opp.AnnualizedYield * 100).ToString("F0"))% APY</span>
                                    </div>
                                    <small class="text-muted">Long: @opp.LongExchangeName | Short: @opp.ShortExchangeName</small>
                                    <div class="small">Spread: @((opp.SpreadPerHour * 100).ToString("F4"))%/hr | Net: @((opp.BoostedNetYieldPerHour * 100).ToString("F4"))%/hr</div>
                                    @if (opp.PredictedSpread.HasValue)
                                    {
                                        <div class="small">Predicted: @((opp.PredictedSpread.Value * 100).ToString("F4"))%/hr (@(opp.PredictedTrend ?? "n/a"))</div>
                                    }
                                    @if (opp.LongVolume24h > 0 || opp.ShortVolume24h > 0)
                                    {
                                        <div><small class="text-muted">Vol: $@opp.LongVolume24h.ToString("N0") / $@opp.ShortVolume24h.ToString("N0")</small></div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
                @* Desktop table view (>= 576px) *@
                <div class="table-responsive d-none d-sm-block">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Asset</th>
                                <th>Mark Price</th>
                                <th>Long Exchange</th>
                                <th>Short Exchange</th>
                                <th>Spread/hr</th>
                                <th>Net Yield/hr</th>
                                <th>Predicted</th>
                                <th>APR</th>
                                <th>Lev</th>
                                <th>ROC APR</th>
                                <th>BE Cyc</th>
                                <th>Next</th>
                            </tr>
                        </thead>
                        <tbody id="opportunities-table-body"
                               data-notional-per-leg="@Model.NotionalPerLeg"
                               data-volume-fraction="@Model.VolumeFraction">
                            @if (Model.Opportunities.Count == 0)
                            {
                                <tr>
                                    <td colspan="12" class="text-center py-4">
                                        @if (Model.Diagnostics is not null)
                                        {
                                            var dx = Model.Diagnostics;
                                            if (dx.TotalRatesLoaded == 0)
                                            {
                                                <div class="alert alert-warning mb-0 d-inline-block">
                                                    No funding rate data available. Background services may not be running.
                                                </div>
                                            }
                                            else if (dx.RatesAfterStalenessFilter == 0)
                                            {
                                                <div class="alert alert-warning mb-0 d-inline-block">
                                                    All @dx.TotalRatesLoaded rates are older than @dx.StalenessMinutes minutes. Exchange connections may be down.
                                                </div>
                                            }
                                            else if (dx.PairsPassing == 0 && dx.PairsFilteredByVolume > 0 && dx.PairsFilteredByThreshold == 0)
                                            {
                                                <div class="alert alert-info mb-0 d-inline-block">
                                                    @dx.PairsFilteredByVolume pairs filtered &mdash; volume below $@dx.MinVolumeThreshold.ToString("N0") on one or both legs.
                                                </div>
                                            }
                                            else if (dx.PairsPassing == 0 && (dx.PairsFilteredByThreshold > 0 || dx.NetPositiveBelowThreshold > 0 || dx.NetPositiveBelowEdgeGuardrail > 0 || dx.PairsFilteredByBreakEvenSize > 0))
                                            {
                                                <div class="alert alert-info mb-0 d-inline-block">
                                                    @(dx.PairsFilteredByThreshold + dx.NetPositiveBelowThreshold + dx.NetPositiveBelowEdgeGuardrail + dx.PairsFilteredByBreakEvenSize) pairs rejected by profitability filters.
                                                    @if (dx.PairsFilteredByThreshold + dx.NetPositiveBelowThreshold > 0)
                                                    {
                                                        <br />
                                                        <strong>@(dx.PairsFilteredByThreshold + dx.NetPositiveBelowThreshold) below @((dx.OpenThreshold * 100).ToString("F3"))% net yield threshold</strong><span>.</span>
                                                    }
                                                    @if (dx.NetPositiveBelowThreshold > 0)
                                                    {
                                                        <strong> @dx.NetPositiveBelowThreshold net-positive below gate (adaptive eligible).</strong>
                                                    }
                                                    @if (dx.PairsFilteredByBreakEvenSize > 0)
                                                    {
                                                        <br />
                                                        <strong>@dx.PairsFilteredByBreakEvenSize filtered by break-even-size floor</strong>
                                                        <span> &mdash; net &times; MinHoldTimeHours below MinEdgeMultiplier &times; fees.</span>
                                                    }
                                                    @if (dx.NetPositiveBelowEdgeGuardrail > 0)
                                                    {
                                                        <br />
                                                        <strong>@dx.NetPositiveBelowEdgeGuardrail above threshold but below the 3&times; edge guardrail</strong>
                                                        <span> &mdash; loosen MinEdgeMultiplier to surface.</span>
                                                    }
                                                    <br />Best raw spread: @((dx.BestRawSpread * 100).ToString("F4"))%.
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">
                                                    No arbitrage opportunities detected at this time.
                                                    <br /><small>Rates are fetched every minute. Check back shortly.</small>
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                No arbitrage opportunities detected at this time.
                                                <br /><small>Rates are fetched every minute. Check back shortly.</small>
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var opp in Model.Opportunities)
                                {
                                    var apyClass = opp.AnnualizedYield > 0.50m
                                        ? "text-success fw-bold"
                                        : opp.AnnualizedYield >= 0.20m
                                            ? "text-warning fw-bold"
                                            : "";
                                    var constrained = IsVolumeConstrained(opp);
                                    <tr class="@(constrained ? "table-warning" : "")">
                                        <td>
                                            <strong>@opp.AssetSymbol</strong>
                                            @if (opp.IsCoinGlassHot)
                                            {
                                                <span class="badge bg-info ms-1" title="Matching cross-exchange arbitrage opportunity on CoinGlass">CG</span>
                                            }
                                        </td>
                                        @{ var displayPrice = opp.LongMarkPrice > 0 && opp.ShortMarkPrice > 0
                                                ? (opp.LongMarkPrice + opp.ShortMarkPrice) / 2
                                                : Math.Max(opp.LongMarkPrice, opp.ShortMarkPrice); }
                                        <td>@FormatPrice(displayPrice)</td>
                                        <td>@opp.LongExchangeName</td>
                                        <td>@opp.ShortExchangeName</td>
                                        <td class="text-info">@((opp.SpreadPerHour * 100).ToString("F4"))%</td>
                                        <td>@((opp.BoostedNetYieldPerHour * 100).ToString("F4"))%</td>
                                        <td>
                                            @if (opp.PredictedSpread.HasValue)
                                            {
                                                var predictedTrend = opp.PredictedTrend ?? "n/a";
                                                var trendArrow = predictedTrend == "rising" ? "^" : predictedTrend == "falling" ? "v" : "-";
                                                var confClass = opp.PredictionConfidence >= 0.7m ? "text-success"
                                                    : opp.PredictionConfidence >= 0.4m ? "text-warning"
                                                    : "text-danger";
                                                <span>@((opp.PredictedSpread.Value * 100).ToString("F4"))%</span>
                                                <span class="trend-arrow @(predictedTrend == "rising" ? "text-success" : predictedTrend == "falling" ? "text-danger" : "text-muted")"
                                                      title="Trend: @predictedTrend">@trendArrow</span>
                                                <span class="prediction-confidence @confClass" title="Confidence: @(((opp.PredictionConfidence ?? 0) * 100).ToString("F0"))%"></span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">&mdash;</span>
                                            }
                                        </td>
                                        <td class="@apyClass">@((opp.AnnualizedYield * 100).ToString("F1"))%</td>
                                        <td class="text-muted small">
                                            @if (opp.EffectiveLeverage.HasValue)
                                            {
                                                @(opp.EffectiveLeverage.Value + "x")
                                            }
                                            else
                                            {
                                                <span>&mdash;</span>
                                            }
                                        </td>
                                        <td class="small">
                                            @if (opp.ReturnOnCapitalPerCycle.HasValue && opp.AprOnCapital.HasValue)
                                            {
                                                var rocClass = opp.AprOnCapital.Value > 100m ? "text-success fw-bold"
                                                    : opp.AprOnCapital.Value > 50m ? "text-warning fw-bold" : "";
                                                <div class="d-flex flex-column">
                                                    <span class="badge bg-primary">@(opp.ReturnOnCapitalPerCycle.Value.ToString("P2"))</span>
                                                    <small class="text-muted @rocClass">@(opp.AprOnCapital.Value.ToString("F1"))% APR</small>
                                                </div>
                                            }
                                            else if (opp.AprOnCapital.HasValue)
                                            {
                                                var rocClass = opp.AprOnCapital.Value > 100m ? "text-success fw-bold"
                                                    : opp.AprOnCapital.Value > 50m ? "text-warning fw-bold" : "";
                                                <span class="@rocClass">@(opp.AprOnCapital.Value.ToString("F0"))%</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">&mdash;</span>
                                            }
                                        </td>
                                        <td class="text-muted small">
                                            @if (opp.BreakEvenCycles.HasValue)
                                            {
                                                @(opp.BreakEvenCycles.Value.ToString("F1"))
                                            }
                                            else
                                            {
                                                <span>&mdash;</span>
                                            }
                                        </td>
                                        <td class="text-muted small">
                                            @if (opp.MinutesToNextSettlement.HasValue)
                                            {
                                                @(opp.MinutesToNextSettlement.Value + "m")
                                            }
                                            else
                                            {
                                                <span>&mdash;</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.IsAuthenticated)
{
    var hasPositions = Model.OpenPositions.Count > 0;
    <div class="row mt-4 @(hasPositions ? "" : "d-none")" id="positions-section">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Open Positions</h5>
                </div>
                <div class="card-body p-0">
                    <div id="positions-empty" class="text-center text-muted py-4 @(hasPositions ? "d-none" : "")">
                        No open positions
                    </div>
                    @* Mobile card view (< 576px) *@
                    <div id="positions-cards" class="d-sm-none p-2">
                        @foreach (var pos in Model.OpenPositions)
                        {
                            var cardBorder = pos.WarningLevel switch {
                                FundingRateArb.Domain.Enums.WarningLevel.Critical => "border-danger",
                                FundingRateArb.Domain.Enums.WarningLevel.Warning  => "border-warning",
                                FundingRateArb.Domain.Enums.WarningLevel.Info     => "border-info",
                                _ => ""
                            };
                            <div class="card mb-2 mobile-card @cardBorder" id="position-card-@pos.Id">
                                <div class="card-body p-2">
                                    <div class="d-flex justify-content-between">
                                        <strong>@pos.AssetSymbol</strong>
                                        <span>
                                            @foreach (var wt in pos.WarningTypes)
                                            {
                                                <span class="warning-icon warning-@wt.ToString().ToLower()" title="@wt">@(wt switch {
                                                    FundingRateArb.Domain.Enums.WarningType.SpreadRisk   => "\u25B2",
                                                    FundingRateArb.Domain.Enums.WarningType.TimeBased    => "\u23F0",
                                                    FundingRateArb.Domain.Enums.WarningType.Loss         => "\u2193",
                                                    FundingRateArb.Domain.Enums.WarningType.Liquidity    => "\u2248",
                                                    FundingRateArb.Domain.Enums.WarningType.Leverage     => "\u26BF",
                                                    FundingRateArb.Domain.Enums.WarningType.PnlProgress  => "\u25CE",
                                                    _ => ""
                                                })</span>
                                            }
                                        </span>
                                    </div>
                                    <small class="text-muted">
                                        @pos.LongExchangeName &rarr; @pos.ShortExchangeName
                                        @if (pos.DivergencePct > 0.01m)
                                        {
                                            <span class="badge bg-info ms-1" title="Price divergence">@pos.DivergencePct.ToString("F2")%</span>
                                        }
                                    </small>
                                    <div class="small">Size: $@pos.SizeUsdc.ToString("F2") | Spread: @((pos.CurrentSpreadPerHour * 100).ToString("F4"))%/hr</div>
                                    <div class="small">
                                        Strategy: <span class="@(pos.UnifiedPnl >= 0 ? "text-success" : "text-danger")">$@pos.UnifiedPnl.ToString("F4")</span>
                                        | Exch: <span class="@(pos.ExchangePnl >= 0 ? "text-success" : "text-danger")">$@pos.ExchangePnl.ToString("F4")</span>
                                    </div>
                                    @if (pos.AccumulatedFunding != 0)
                                    {
                                        <div class="small">Funding: $@pos.AccumulatedFunding.ToString("F4")</div>
                                    }
                                    @if (Model.AdaptiveHoldEnabled && Model.PnlProgressByPosition.TryGetValue(pos.Id, out var mobileProgress))
                                    {
                                        var mPct = Math.Min(mobileProgress * 100, 100);
                                        var mBarClass = mPct > 95 ? "pnl-fill-pulse" : mPct > 80 ? "pnl-fill-gold" : "pnl-fill-green";
                                        <div class="mt-1">
                                            <div class="pnl-progress-bar">
                                                <div class="pnl-progress-fill @mBarClass" style="width: @(mPct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                            </div>
                                            <small class="text-muted">PnL Target: @mPct.ToString("F0")%</small>
                                        </div>
                                    }
                                    <div class="border-top mt-1 pt-1"><small class="text-muted">Opened <time datetime="@((pos.ConfirmedAtUtc ?? pos.OpenedAt).ToString("o"))" class="local-time">@((pos.ConfirmedAtUtc ?? pos.OpenedAt).ToString("MMM dd HH:mm")) UTC</time></small></div>
                                </div>
                            </div>
                        }
                    </div>
                    @* Desktop table view (>= 576px) *@
                    <div class="table-responsive d-none d-sm-block">
                        <table id="positions-table" class="table table-hover mb-0" data-details-base-url="@Url.Action("Details", "Positions")">
                            <thead class="table-light">
                                <tr>
                                    <th>Asset</th>
                                    <th>Long</th>
                                    <th>Short</th>
                                    <th>Size (USDC)</th>
                                    <th>Entry Spread/hr</th>
                                    <th>Current Spread/hr</th>
                                    <th>Strategy PnL</th>
                                    <th>Exch. PnL</th>
                                    <th>Funding</th>
                                    @if (Model.AdaptiveHoldEnabled)
                                    {
                                        <th>PnL Target</th>
                                    }
                                    <th>Opened At</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pos in Model.OpenPositions)
                                {
                                    var warningRowClass = pos.WarningLevel switch {
                                        FundingRateArb.Domain.Enums.WarningLevel.Critical => "table-danger",
                                        FundingRateArb.Domain.Enums.WarningLevel.Warning  => "table-warning",
                                        FundingRateArb.Domain.Enums.WarningLevel.Info     => "table-info",
                                        _ => ""
                                    };
                                    <tr id="position-@pos.Id" class="@warningRowClass">
                                        <td>
                                            <strong>@pos.AssetSymbol</strong>
                                            @foreach (var wt in pos.WarningTypes)
                                            {
                                                <span class="warning-icon warning-@wt.ToString().ToLower()" title="@wt">@(wt switch {
                                                    FundingRateArb.Domain.Enums.WarningType.SpreadRisk   => "\u25B2",
                                                    FundingRateArb.Domain.Enums.WarningType.TimeBased    => "\u23F0",
                                                    FundingRateArb.Domain.Enums.WarningType.Loss         => "\u2193",
                                                    FundingRateArb.Domain.Enums.WarningType.Liquidity    => "\u2248",
                                                    FundingRateArb.Domain.Enums.WarningType.Leverage     => "\u26BF",
                                                    FundingRateArb.Domain.Enums.WarningType.PnlProgress  => "\u25CE",
                                                    _ => ""
                                                })</span>
                                            }
                                        </td>
                                        <td>@pos.LongExchangeName</td>
                                        <td>@pos.ShortExchangeName</td>
                                        <td>$@pos.SizeUsdc.ToString("F2")</td>
                                        <td>@((pos.EntrySpreadPerHour * 100).ToString("F4"))%</td>
                                        <td class="position-spread @(pos.CurrentSpreadPerHour >= 0 ? "text-success" : "text-danger")">
                                            @((pos.CurrentSpreadPerHour * 100).ToString("F4"))%
                                        </td>
                                        <td class="position-pnl @(pos.UnifiedPnl >= 0 ? "text-success" : "text-danger")">$@pos.UnifiedPnl.ToString("F4")</td>
                                        <td class="position-exchange-pnl @(pos.ExchangePnl >= 0 ? "text-success" : "text-danger")">
                                            $@pos.ExchangePnl.ToString("F4")
                                            <span class="badge bg-info ms-1 divergence-badge" title="Price divergence"
                                                  style="@(pos.DivergencePct > 0.01m ? "" : "display:none")">@pos.DivergencePct.ToString("F2")%</span>
                                        </td>
                                        <td class="@(pos.AccumulatedFunding >= 0 ? "text-success" : "text-danger")">$@pos.AccumulatedFunding.ToString("F4")</td>
                                        @if (Model.AdaptiveHoldEnabled)
                                        {
                                            <td>
                                                @if (Model.PnlProgressByPosition.TryGetValue(pos.Id, out var progress))
                                                {
                                                    var pct = Math.Min(progress * 100, 100);
                                                    var barClass = pct > 95 ? "pnl-fill-pulse" : pct > 80 ? "pnl-fill-gold" : "pnl-fill-green";
                                                    <div class="pnl-progress-bar">
                                                        <div class="pnl-progress-fill @barClass" style="width: @(pct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                                    </div>
                                                    <small class="text-muted">@pct.ToString("F0")%</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">&mdash;</span>
                                                }
                                            </td>
                                        }
                                        <td><time datetime="@((pos.ConfirmedAtUtc ?? pos.OpenedAt).ToString("o"))" class="local-time">@((pos.ConfirmedAtUtc ?? pos.OpenedAt).ToString("yyyy-MM-dd HH:mm")) UTC</time></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.IsAuthenticated)
{
    <div class="row mt-4">
        @* Active Cooldowns Panel *@
        <div class="col-md-6 mb-3" id="active-cooldowns-panel">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Active Cooldowns</h6>
                    <span class="badge bg-secondary">@Model.ActiveCooldowns.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.ActiveCooldowns.Count == 0)
                    {
                        <p class="text-muted text-center py-3 mb-0 small">No active cooldowns.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="small">Pair</th>
                                        <th class="small">Remaining</th>
                                        <th class="small">Expires At</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cd in Model.ActiveCooldowns)
                                    {
                                        <tr>
                                            <td class="small text-break">@cd.DisplayName</td>
                                            <td class="small">@cd.RemainingMinutes min</td>
                                            <td class="small"><time class="local-time" datetime="@cd.ExpiresAt.ToString("o")">@cd.ExpiresAt.ToString("HH:mm") UTC</time></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Circuit Breaker Health Panel *@
        <div class="col-md-6 mb-3" id="circuit-breaker-panel">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Exchange Health</h6>
                    @if (Model.LastFundingRateFetch.HasValue)
                    {
                        <small class="text-muted">Last fetch: <time class="local-time" datetime="@Model.LastFundingRateFetch.Value.ToString("o")">@Model.LastFundingRateFetch.Value.ToString("HH:mm") UTC</time></small>
                    }
                </div>
                <div class="card-body">
                    @if (Model.CircuitBreakerStates.Count == 0)
                    {
                        <p class="text-success mb-0 small">All exchanges healthy.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var cb in Model.CircuitBreakerStates)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-1">
                                    <span class="small">@cb.ExchangeName</span>
                                    <span class="badge bg-danger">Open &mdash; @cb.RemainingMinutes min</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/shared-time.js" asp-append-version="true"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
