@model FundingRateArb.Web.ViewModels.ApiKeyViewModel
@{
    ViewData["Title"] = "API Keys";
    ViewData["ActiveTab"] = "ApiKeys";
}

<h2 class="mb-3">Settings</h2>

@await Html.PartialAsync("_SettingsNav")

<div class="alert alert-info d-flex align-items-center mb-4" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
         class="bi bi-shield-lock-fill me-2 flex-shrink-0" viewBox="0 0 16 16">
        <path fill-rule="evenodd"
              d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.777 11.777 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.208.829.208s.548-.076.829-.208a7.198 7.198 0 0 0 1.048-.625 11.777 11.777 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.541 1.541 0 0 0-1.044-1.263 62.467 62.467 0 0 0-2.887-.87C9.843.266 8.69 0 8 0zm0 5a1.5 1.5 0 0 1 .5 2.915l.385 1.99a.5.5 0 0 1-.491.595h-.788a.5.5 0 0 1-.49-.595l.384-1.99A1.5 1.5 0 0 1 8 5z" />
    </svg>
    <span>Your API keys are encrypted at rest using the Data Protection API. They are never stored in plain text.</span>
</div>

@if (Model.Exchanges.Any(e => e.ExchangeType == "cex" || e.ExchangeType == "aster-v3"))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <strong>IP Whitelisting recommended:</strong> For Aster and Binance API keys, enable IP
        whitelisting in the exchange's API management page. Check your deployment's outbound IP
        before adding it to the allowlist.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.TestResultMessage != null)
{
    var alertClass = Model.TestResultSuccess == true ? "alert-success" : "alert-danger";
    <div class="alert @alertClass alert-dismissible fade show" role="alert">
        @Model.TestResultMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Exchanges.Any())
{
    <div class="alert alert-warning">
        No exchanges are currently enabled by the administrator. Contact your admin to enable exchanges.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var exchange in Model.Exchanges)
        {
            <div class="col-12 col-lg-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-semibold">@exchange.ExchangeName</h5>
                        <div class="d-flex flex-column align-items-end">
                            @if (exchange.IsConfigured)
                            {
                                <span class="badge bg-success">Configured</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Not Set</span>
                            }
                            @if (exchange.LastUsedAt.HasValue)
                            {
                                var diff = DateTime.UtcNow - exchange.LastUsedAt.Value;
                                string relativeTime;
                                if (diff.TotalMinutes < 1)
                                {
                                    relativeTime = "just now";
                                }
                                else if (diff.TotalHours < 1)
                                {
                                    relativeTime = $"{(int)diff.TotalMinutes}m ago";
                                }
                                else if (diff.TotalDays < 1)
                                {
                                    relativeTime = $"{(int)diff.TotalHours}h ago";
                                }
                                else
                                {
                                    relativeTime = $"{(int)diff.TotalDays}d ago";
                                }
                                <small class="text-muted">Last used: @relativeTime</small>
                            }
                        </div>
                    </div>
                    <div class="card-body">

                        @* Save form *@
                        <form asp-controller="Settings" asp-action="SaveApiKey" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="exchangeId" value="@exchange.ExchangeId" />

                            @if (exchange.ExchangeType == "cex")
                            {
                                @* CEX-style: API Key + API Secret (e.g. Aster) *@
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">API Key</label>
                                    @if (exchange.IsConfigured && exchange.MaskedApiKey is not null)
                                    {
                                        <div class="input-group mb-1">
                                            <span class="input-group-text bg-light text-muted font-monospace small">
                                                @exchange.MaskedApiKey
                                            </span>
                                        </div>
                                        <div class="form-text">Leave blank to keep the existing key.</div>
                                    }
                                    <input type="password" class="form-control" name="apiKey"
                                           autocomplete="new-password"
                                           placeholder="@(exchange.IsConfigured ? "Enter new API key to replace" : "Enter API key")" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">API Secret</label>
                                    @if (exchange.IsConfigured)
                                    {
                                        <div class="form-text mb-1">Leave blank to keep the existing secret.</div>
                                    }
                                    <input type="password" class="form-control" name="apiSecret"
                                           autocomplete="new-password"
                                           placeholder="@(exchange.IsConfigured ? "Enter new API secret to replace" : "Enter API secret")" />
                                </div>
                            }
                            else if (exchange.ExchangeType == "hyperliquid")
                            {
                                @* Hyperliquid: Master Wallet Address + Agent Private Key + optional Sub-Account Address *@
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Master Wallet Address</label>
                                    @if (exchange.IsConfigured && exchange.MaskedWalletAddress is not null)
                                    {
                                        <div class="input-group mb-1">
                                            <span class="input-group-text bg-light text-muted font-monospace small">
                                                @exchange.MaskedWalletAddress
                                            </span>
                                        </div>
                                        <div class="form-text">Leave blank to keep the existing address.</div>
                                    }
                                    <input type="password" class="form-control" name="walletAddress"
                                           autocomplete="new-password"
                                           placeholder="Enter your Ethereum wallet address (0x...)" />
                                    <div class="form-text">42-character hex address starting with 0x</div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Agent Private Key</label>
                                    @if (exchange.IsConfigured)
                                    {
                                        <div class="form-text mb-1">Leave blank to keep the existing key.</div>
                                    }
                                    <input type="password" class="form-control" name="privateKey"
                                           autocomplete="new-password"
                                           placeholder="Enter agent wallet private key from app.hyperliquid.xyz" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Sub-Account Address <span class="text-muted fw-normal">(optional)</span></label>
                                    @if (exchange.IsConfigured && exchange.MaskedSubAccountAddress is not null)
                                    {
                                        <div class="input-group mb-1">
                                            <span class="input-group-text bg-light text-muted font-monospace small">
                                                @exchange.MaskedSubAccountAddress
                                            </span>
                                        </div>
                                    }
                                    <input type="password" class="form-control" name="subAccountAddress"
                                           autocomplete="new-password"
                                           placeholder="Optional — enter sub-account address for vault trading (0x...)" />
                                    <div class="form-text">Leave blank if trading on your main account. Required only for sub-account trading.</div>
                                </div>
                            }
                            else if (exchange.ExchangeType == "lighter")
                            {
                                @* Lighter: Account Index + API Key Index + API Private Key *@
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Account Index</label>
                                    @if (exchange.IsConfigured && exchange.MaskedWalletAddress is not null)
                                    {
                                        <div class="input-group mb-1">
                                            <span class="input-group-text bg-light text-muted font-monospace small">
                                                @exchange.MaskedWalletAddress
                                            </span>
                                        </div>
                                        <div class="form-text">Leave blank to keep the existing account index.</div>
                                    }
                                    <input type="text" class="form-control" name="walletAddress"
                                           autocomplete="off"
                                           placeholder="Enter your numeric account index (e.g. 12345)" />
                                    <div class="form-text">Numeric integer</div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">API Key Index</label>
                                    @if (exchange.IsConfigured && exchange.MaskedApiKeyIndex is not null)
                                    {
                                        <div class="input-group mb-1">
                                            <span class="input-group-text bg-light text-muted font-monospace small">
                                                @exchange.MaskedApiKeyIndex
                                            </span>
                                        </div>
                                        <div class="form-text">Leave blank to keep the existing API key index.</div>
                                    }
                                    <input type="text" class="form-control" name="apiKeyIndex"
                                           autocomplete="off"
                                           placeholder="Enter API key index (2-254)" />
                                    <div class="form-text">Integer between 2 and 254</div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">API Private Key</label>
                                    @if (exchange.IsConfigured)
                                    {
                                        <div class="form-text mb-1">Leave blank to keep the existing private key.</div>
                                    }
                                    <input type="password" class="form-control" name="privateKey"
                                           autocomplete="new-password"
                                           placeholder="Enter the private key for this API key index" />
                                </div>
                            }
                            else if (exchange.ExchangeType == "dydx")
                            {
                                @* dYdX: BIP39 mnemonic (24-word secret phrase) *@
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Secret Phrase</label>
                                    @if (exchange.IsConfigured && exchange.MaskedPrivateKey is not null)
                                    {
                                        <div class="input-group mb-1">
                                            <span class="input-group-text bg-light text-muted font-monospace small">
                                                @exchange.MaskedPrivateKey
                                            </span>
                                        </div>
                                        <div class="form-text">Leave blank to keep the existing phrase.</div>
                                    }
                                    <textarea class="form-control" name="privateKey"
                                              autocomplete="new-password"
                                              rows="3"
                                              placeholder="Enter your 24-word dYdX Chain secret phrase (space-separated)"></textarea>
                                    <small class="text-muted">Your dYdX Chain address is derived from this phrase and stored securely. The phrase is never shown after saving.</small>
                                </div>
                            }
                            else if (exchange.ExchangeType == "aster-v3")
                            {
                                @* V1 legacy migration banner — shown only for users with old HMAC credentials *@
                                @if (exchange.HasLegacyV1Credentials)
                                {
                                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                                        You are using V1 HMAC credentials. Upgrade to V3 Pro API keys for improved security.
                                        <a href="https://pro.aster.exchange/" target="_blank" rel="noopener noreferrer">Manage API wallets</a>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                }

                                @* V3 Pro API form: User Private Key + Signer Private Key *@
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">User Private Key</label>
                                    @if (exchange.IsConfigured && exchange.MaskedWalletAddress is not null)
                                    {
                                        <div class="input-group mb-1">
                                            <span class="input-group-text bg-light text-muted font-monospace small">
                                                @exchange.MaskedWalletAddress
                                            </span>
                                        </div>
                                        <div class="form-text">Leave blank to keep the existing user private key.</div>
                                    }
                                    <input type="password" class="form-control" name="walletAddress"
                                           autocomplete="new-password"
                                           placeholder="0x + 64 hex chars"
                                           pattern="^(0x)?[0-9a-fA-F]{64}$" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Signer Private Key</label>
                                    @if (exchange.IsConfigured && exchange.MaskedPrivateKey is not null)
                                    {
                                        <div class="input-group mb-1">
                                            <span class="input-group-text bg-light text-muted font-monospace small">
                                                @exchange.MaskedPrivateKey
                                            </span>
                                        </div>
                                        <div class="form-text">Leave blank to keep the existing signer private key.</div>
                                    }
                                    <input type="password" class="form-control" name="privateKey"
                                           autocomplete="new-password"
                                           placeholder="0x + 64 hex chars"
                                           pattern="^(0x)?[0-9a-fA-F]{64}$" />
                                </div>
                                <input type="hidden" name="exchangeType" value="aster-v3" />
                            }

                            <div class="d-flex gap-2 mt-3">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    @(exchange.IsConfigured ? "Update Keys" : "Save Keys")
                                </button>

                                @if (exchange.IsConfigured)
                                {
                                    @* Delete button triggers confirmation modal *@
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal-@exchange.ExchangeId">
                                        Delete
                                    </button>
                                }
                            </div>
                        </form>

                        @* Test Connection button — user-initiated only, never auto-fires *@
                        <form asp-action="TestApiKey" asp-route-exchangeId="@exchange.ExchangeId" method="post" class="d-inline mt-2">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-secondary btn-sm">Test Connection</button>
                        </form>
                    </div>
                </div>
            </div>

            @* Delete confirmation modal (outside the save form) *@
            @if (exchange.IsConfigured)
            {
                <div class="modal fade" id="deleteModal-@exchange.ExchangeId" tabindex="-1"
                     aria-labelledby="deleteModalLabel-@exchange.ExchangeId" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="deleteModalLabel-@exchange.ExchangeId">
                                    Delete @exchange.ExchangeName Keys
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <p>Are you sure you want to delete your API keys for <strong>@exchange.ExchangeName</strong>?</p>
                                <p class="text-danger mb-0">
                                    This action cannot be undone. The bot will stop trading on this exchange until new keys are provided.
                                </p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <form asp-controller="Settings" asp-action="DeleteApiKey" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="exchangeId" value="@exchange.ExchangeId" />
                                    <button type="submit" class="btn btn-danger">Delete Keys</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}
