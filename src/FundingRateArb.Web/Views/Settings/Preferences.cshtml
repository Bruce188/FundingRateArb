@model FundingRateArb.Web.ViewModels.PreferencesViewModel

@{
    ViewData["Title"] = "Exchanges & Coins";
    ViewData["ActiveTab"] = "Preferences";
}

<h2 class="mb-3">Settings</h2>

@await Html.PartialAsync("_SettingsLayout")

@if (Model.StatusMessage is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form id="preferencesForm" asp-controller="Settings" asp-action="Preferences" method="post">
    @Html.AntiForgeryToken()

    @* --- Exchanges Section --- *@
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <h5 class="mb-0 fw-semibold">Trading Exchanges</h5>
            <small class="text-muted">Select at least 2 exchanges for arbitrage</small>
        </div>
        <div class="card-body">
            @if (!Model.Exchanges.Any())
            {
                <div class="alert alert-warning mb-0">
                    No exchanges are currently enabled by the administrator.
                </div>
            }
            else
            {
                <div id="exchange-validation-warning" class="alert alert-warning d-none mb-3" role="alert">
                    At least 2 exchanges must be enabled for arbitrage.
                </div>

                @foreach (var exchange in Model.Exchanges)
                {
                    <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input exchange-toggle"
                                       type="checkbox"
                                       role="switch"
                                       id="exchange-@exchange.ExchangeId"
                                       name="enabledExchangeIds"
                                       value="@exchange.ExchangeId"
                                       @(exchange.IsEnabled ? "checked" : "") />
                                <label class="form-check-label fw-semibold" for="exchange-@exchange.ExchangeId">
                                    @exchange.ExchangeName
                                </label>
                            </div>
                            @if (exchange.HasCredentials)
                            {
                                <span class="badge bg-success">API Keys Configured</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Not Configured</span>
                            }
                        </div>
                        @if (!exchange.HasCredentials)
                        {
                            <a href="/Settings/ApiKeys" class="btn btn-outline-warning btn-sm">Set Up Keys</a>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @* --- Assets/Coins Section --- *@
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h5 class="mb-0 fw-semibold">Trading Coins</h5>
                <small class="text-muted">Select at least 1 coin to trade</small>
            </div>
            <div class="d-flex gap-2">
                <button type="button" id="enableAllAssets" class="btn btn-outline-primary btn-sm">Enable All</button>
                <button type="button" id="disableAllAssets" class="btn btn-outline-secondary btn-sm">Disable All</button>
            </div>
        </div>
        <div class="card-body">
            @if (!Model.Assets.Any())
            {
                <div class="alert alert-warning mb-0">
                    No coins are currently enabled by the administrator.
                </div>
            }
            else
            {
                <div id="asset-validation-warning" class="alert alert-warning d-none mb-3" role="alert">
                    At least 1 coin must be enabled to trade.
                </div>

                <div class="row g-2">
                    @foreach (var asset in Model.Assets)
                    {
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                            <div class="form-check form-switch mb-0 py-1">
                                <input class="form-check-input asset-toggle"
                                       type="checkbox"
                                       role="switch"
                                       id="asset-@asset.AssetId"
                                       name="enabledAssetIds"
                                       value="@asset.AssetId"
                                       @(asset.IsEnabled ? "checked" : "") />
                                <label class="form-check-label" for="asset-@asset.AssetId">
                                    <span class="fw-semibold">@asset.Symbol</span>
                                    <span class="text-muted small ms-1">@asset.Name</span>
                                </label>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end">
        <button type="submit" id="saveBtn" class="btn btn-primary px-4">
            Save Preferences
        </button>
    </div>
</form>

@section Scripts {
    <script>
        // Enable/Disable All assets
        document.getElementById('enableAllAssets')?.addEventListener('click', () => {
            document.querySelectorAll('.asset-toggle').forEach(cb => cb.checked = true);
            validateAssets();
        });

        document.getElementById('disableAllAssets')?.addEventListener('click', () => {
            document.querySelectorAll('.asset-toggle').forEach(cb => cb.checked = false);
            validateAssets();
        });

        function validateExchanges() {
            const count = document.querySelectorAll('.exchange-toggle:checked').length;
            const warning = document.getElementById('exchange-validation-warning');
            if (warning) warning.classList.toggle('d-none', count >= 2);
        }

        function validateAssets() {
            const count = document.querySelectorAll('.asset-toggle:checked').length;
            const warning = document.getElementById('asset-validation-warning');
            if (warning) warning.classList.toggle('d-none', count >= 1);
        }

        document.querySelectorAll('.exchange-toggle').forEach(cb => {
            cb.addEventListener('change', validateExchanges);
        });

        document.querySelectorAll('.asset-toggle').forEach(cb => {
            cb.addEventListener('change', validateAssets);
        });

        // Client-side pre-submit validation
        document.getElementById('preferencesForm')?.addEventListener('submit', function (e) {
            const exchangeCount = document.querySelectorAll('.exchange-toggle:checked').length;
            const assetCount = document.querySelectorAll('.asset-toggle:checked').length;
            let valid = true;

            if (exchangeCount < 2) {
                const warning = document.getElementById('exchange-validation-warning');
                if (warning) warning.classList.remove('d-none');
                valid = false;
            }

            if (assetCount < 1) {
                const warning = document.getElementById('asset-validation-warning');
                if (warning) warning.classList.remove('d-none');
                valid = false;
            }

            if (!valid) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });
    </script>
}
