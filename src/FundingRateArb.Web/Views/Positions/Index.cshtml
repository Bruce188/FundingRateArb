@model FundingRateArb.Web.ViewModels.PositionIndexViewModel
@using FundingRateArb.Domain.Enums

@{
    ViewData["Title"] = "Positions";
}

<h2>Positions</h2>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Positions.Any())
{
    <div class="alert alert-info">No positions found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover" id="positions-table" data-details-base-url="@Url.Action("Details", "Positions")">
            <thead class="table-dark">
                <tr>
                    <th>Asset</th>
                    <th>Long Exchange</th>
                    <th>Short Exchange</th>
                    <th>Status</th>
                    <th>Close Reason</th>
                    <th class="text-end">Size (USDC)</th>
                    <th class="text-end">Spread/hr</th>
                    <th class="text-end">Strategy PnL</th>
                    <th class="text-end">Exch. PnL</th>
                    <th class="text-end">Divergence</th>
                    <th class="text-end">Funding</th>
                    <th>Opened</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pos in Model.Positions)
                {
                    <tr data-position-id="@pos.Id" tabindex="0" role="link" style="cursor:pointer;">
                        <td>@pos.AssetSymbol</td>
                        <td>@pos.LongExchangeName</td>
                        <td>@pos.ShortExchangeName</td>
                        <td>
                            @{
                                var badgeClass = pos.Status switch
                                {
                                    PositionStatus.Opening => "bg-info",
                                    PositionStatus.Open => "bg-success",
                                    PositionStatus.Closing => "bg-warning text-dark",
                                    PositionStatus.Closed => "bg-secondary",
                                    PositionStatus.EmergencyClosed => "bg-warning text-dark border border-danger",
                                    PositionStatus.Liquidated => "bg-danger",
                                    PositionStatus.Failed => "bg-danger text-white",
                                    _ => "bg-secondary",
                                };
                                var badgeText = pos.Status == PositionStatus.EmergencyClosed ? "Emergency Closed" : pos.Status.ToString();
                            }
                            <span class="badge pos-status @badgeClass">
                                @if (pos.Status == PositionStatus.Failed)
                                {
                                    <i class="bi bi-exclamation-triangle"></i>
                                }
                                @badgeText
                            </span>
                            @if (pos.IsDryRun)
                            {
                                <span class="badge bg-warning text-dark ms-1">Paper</span>
                            }
                        </td>
                        <td>
                            @if (pos.CloseReasonDisplayName is not null)
                            {
                                <span title="@pos.CloseReason">@pos.CloseReasonDisplayName</span>
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td class="text-end">@pos.SizeUsdc.ToString("F2")</td>
                        <td class="text-end pos-spread">@pos.CurrentSpreadPerHour.ToString("P4")</td>
                        <td class="position-pnl text-end @(pos.UnifiedPnl >= 0 ? "text-success" : "text-danger")">
                            $@pos.UnifiedPnl.ToString("F4")
                        </td>
                        <td class="position-exchange-pnl text-end @(pos.ExchangePnl >= 0 ? "text-success" : "text-danger")">
                            $@pos.ExchangePnl.ToString("F4")
                        </td>
                        <td class="text-end">
                            @if (pos.DivergencePct > 0.01m)
                            {
                                <span class="badge bg-info" title="Cross-exchange price divergence (|longMark - shortMark| / unified)">@pos.DivergencePct.ToString("F2")%</span>
                                @if (pos.IsDivergenceNarrowing)
                                {
                                    <i class="bi bi-arrow-down-circle text-success ms-1" title="Narrowing"></i>
                                }
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td class="pos-funding text-end @(pos.AccumulatedFunding >= 0 ? "text-success" : "text-danger")">
                            @pos.AccumulatedFunding.ToString("F4")
                        </td>
                        <td><time datetime="@((pos.ConfirmedAtUtc ?? pos.OpenedAt).ToString("o"))" class="local-time">@((pos.ConfirmedAtUtc ?? pos.OpenedAt).ToString("yyyy-MM-dd HH:mm"))</time></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@pos.Id" class="btn btn-sm btn-outline-primary me-1">Details</a>
                            <a href="/Analytics/PositionAnalysis?id=@pos.Id" class="btn btn-sm btn-outline-secondary me-1" title="Analyse"><i class="bi bi-graph-up"></i></a>
                            @if (pos.Status == PositionStatus.Open)
                            {
                                <form asp-action="Close" asp-route-id="@pos.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Close this position?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Close</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script src="~/js/shared-time.js" asp-append-version="true"></script>
    <script src="~/js/positions.js" asp-append-version="true"></script>
    <script>
        var posTable = document.getElementById("positions-table");
        var detailsBaseUrl = (posTable && posTable.getAttribute("data-details-base-url")) || "/Positions/Details";
        document.querySelectorAll("tr[data-position-id]").forEach(function(row) {
            function navigate() { window.location.href = detailsBaseUrl + "/" + row.dataset.positionId; }
            row.addEventListener("click", function(e) {
                if (e.target.closest("a, button, form")) return;
                navigate();
            });
            row.addEventListener("keydown", function(e) {
                if (e.key === "Enter") navigate();
            });
        });
    </script>
}
