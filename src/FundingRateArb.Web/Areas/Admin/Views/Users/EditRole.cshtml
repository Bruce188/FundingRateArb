@model UserRoleViewModel
@{
    ViewData["Title"] = "Edit User Role";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Edit User Role</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Users</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-4">
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Display Name</dt>
            <dd class="col-sm-9">@Model.DisplayName</dd>

            <dt class="col-sm-3">Current Roles</dt>
            <dd class="col-sm-9">
                @foreach (var role in Model.Roles)
                {
                    <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") me-1">@role</span>
                }
                @if (!Model.Roles.Any())
                {
                    <span class="text-muted">No roles assigned</span>
                }
            </dd>
        </dl>

        <form asp-action="EditRole" method="post">
            <input asp-for="UserId" type="hidden" />
            <input asp-for="Email" type="hidden" />
            <input asp-for="DisplayName" type="hidden" />

            <div class="mb-3">
                <label class="form-label fw-bold">Assign Role</label>
                <div class="d-flex gap-3">
                    @foreach (var roleOption in Model.AvailableRoles ?? [])
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="Roles"
                                   value="@roleOption.Value"
                                   id="role_@roleOption.Value"
                                   @(Model.Roles.Contains(roleOption.Value) ? "checked" : "") />
                            <label class="form-check-label" for="role_@roleOption.Value">
                                @roleOption.Text
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Update Role</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
