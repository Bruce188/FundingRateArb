@model IEnumerable<UserRoleViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Users</h1>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        @* Mobile card view (< 576px) *@
        <div class="d-sm-none p-2">
            @foreach (var user in Model)
            {
                <div class="card mb-2 mobile-card">
                    <div class="card-body p-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <strong>@user.Email</strong>
                            <a asp-action="EditRole" asp-route-userId="@user.UserId" class="btn btn-sm btn-outline-primary">Edit</a>
                        </div>
                        @if (!string.IsNullOrEmpty(user.DisplayName))
                        {
                            <small class="text-muted">@user.DisplayName</small>
                        }
                        <div class="mt-1">
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") me-1">@role</span>
                            }
                            @if (!user.Roles.Any())
                            {
                                <span class="text-muted small">No roles</span>
                            }
                        </div>
                    </div>
                </div>
            }
            @if (!Model.Any())
            {
                <p class="text-muted text-center py-4 mb-0">No users found.</p>
            }
        </div>
        @* Desktop table view (>= 576px) *@
        <div class="d-none d-sm-block">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Email</th>
                        <th>Display Name</th>
                        <th>Roles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>@user.DisplayName</td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") me-1">@role</span>
                                }
                                @if (!user.Roles.Any())
                                {
                                    <span class="text-muted">No roles</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EditRole" asp-route-userId="@user.UserId" class="btn btn-sm btn-outline-primary">Edit Role</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No users found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
