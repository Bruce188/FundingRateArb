@model FundingRateArb.Domain.Entities.Asset
@{
    ViewData["Title"] = "Delete Asset";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Delete Asset</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card shadow-sm border-danger">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0">Confirm Deletion</h5>
    </div>
    <div class="card-body">
        <p class="text-danger fw-bold">Are you sure you want to delete this asset? This action cannot be undone.</p>

        <dl class="row">
            <dt class="col-sm-3">Symbol</dt>
            <dd class="col-sm-9"><strong>@Model.Symbol</strong></dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Active</dt>
            <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
        </dl>

        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Delete Asset</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
