@{
    ViewData["Title"] = "Connectivity Test";
    var users = (IEnumerable<dynamic>)ViewBag.Users;
    var exchanges = (List<FundingRateArb.Domain.Entities.Exchange>)ViewBag.Exchanges;
    var usersTruncated = (bool)(ViewBag.UsersTruncated ?? false);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3"><i class="bi bi-plug"></i> Exchange Connectivity Test</h1>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white">
        <i class="bi bi-person"></i> Select User
    </div>
    <div class="card-body">
        <div class="row align-items-end">
            <div class="col-md-6">
                <label for="userSelect" class="form-label">User</label>
                <select id="userSelect" class="form-select">
                    <option value="">-- Select a user --</option>
                    @foreach (var user in users)
                    {
                        <option value="@user.Id">@user.UserName (@user.Email)</option>
                    }
                </select>
                @if (usersTruncated)
                {
                    <div class="form-text text-warning">
                        <i class="bi bi-exclamation-triangle"></i> Showing first 500 users. Not all users are listed.
                    </div>
                }
            </div>
            <div class="col-md-6 mt-2 mt-md-0">
                <button id="btnTestAll" class="btn btn-primary" disabled>
                    <i class="bi bi-play-fill"></i> Test All Exchanges
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white">
        <i class="bi bi-toggles"></i> Test Mode
    </div>
    <div class="card-body">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="dryRunRadio" id="radioDryRun" value="true" checked
                       onclick="document.getElementById('dryRunInput').value='true'; document.getElementById('liveTradeWarning').style.display='none';" />
                <label class="form-check-label" for="radioDryRun">
                    <i class="bi bi-shield-check text-success"></i> Dry Run <small class="text-muted">(read-only)</small>
                </label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="dryRunRadio" id="radioLiveTrade" value="false"
                       onclick="document.getElementById('dryRunInput').value='false'; document.getElementById('liveTradeWarning').style.display='';" />
                <label class="form-check-label" for="radioLiveTrade">
                    <i class="bi bi-exclamation-triangle text-warning"></i> Live Trade <small class="text-muted">(real orders)</small>
                </label>
            </div>
        </div>
        <input type="hidden" id="dryRunInput" value="true" />
        <div id="liveTradeWarning" class="alert alert-warning mt-3 mb-0" style="display:none;">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <strong>Warning:</strong> Live Trade mode places a real $10 order on mainnet using your API credentials. Use only for diagnostics.
        </div>
    </div>
</div>

<div class="row mb-4" id="exchangeCards">
    @foreach (var exchange in exchanges)
    {
        <div class="col-md-4 col-lg-3 mb-3">
            <div class="card shadow-sm h-100" data-exchange-id="@exchange.Id">
                <div class="card-body text-center">
                    <h5 class="card-title">@exchange.Name</h5>
                    <span class="badge bg-secondary mb-3 exchange-status" id="status-@exchange.Id">Idle</span>
                    <div>
                        <button class="btn btn-outline-primary btn-test"
                                data-exchange-id="@exchange.Id"
                                data-exchange-name="@exchange.Name"
                                disabled>
                            <span class="spinner-border spinner-border-sm d-none" role="status"></span>
                            <i class="bi bi-lightning-charge"></i> Test
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <span><i class="bi bi-terminal"></i> Log Output <span id="modeBadge" class="badge ms-2"></span></span>
        <button id="btnClearLog" class="btn btn-sm btn-outline-light">
            <i class="bi bi-trash"></i> Clear
        </button>
    </div>
    <div class="card-body p-0">
        <pre id="logPanel" class="mb-0 p-3" style="background-color: #1e1e1e; color: #d4d4d4; max-height: 400px; overflow-y: auto; font-size: 0.85rem; min-height: 100px; white-space: pre-wrap; word-break: break-word;"></pre>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/connectivity-test.js"></script>
}
