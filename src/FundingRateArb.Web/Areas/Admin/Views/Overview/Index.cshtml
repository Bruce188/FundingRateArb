@model FundingRateArb.Web.ViewModels.AdminOverviewViewModel
@{
    ViewData["Title"] = "Admin Overview";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Admin Overview</h1>
    <div>
        <a asp-area="Admin" asp-controller="BotConfig" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            Bot Configuration
        </a>
    </div>
</div>

@* Global Kill Switch Status *@
<div class="alert @(Model.GlobalBotEnabled ? "alert-success" : "alert-danger") d-flex align-items-center mb-4" role="alert">
    <strong class="me-2">Global Bot Status:</strong>
    @if (Model.GlobalBotEnabled)
    {
        <span class="badge bg-success fs-6 px-3 py-2 me-3">RUNNING</span>
        <span>All user bots are operational. Use <a asp-area="Admin" asp-controller="BotConfig" asp-action="Index" class="alert-link">Bot Configuration</a> to stop all activity.</span>
    }
    else
    {
        <span class="badge bg-danger fs-6 px-3 py-2 me-3">STOPPED</span>
        <span>Global kill switch is active — all user bots are halted. <a asp-area="Admin" asp-controller="BotConfig" asp-action="Index" class="alert-link">Re-enable in Bot Configuration.</a></span>
    }
</div>

@* KPI Cards *@
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Active Users</div>
                <div class="display-6 fw-bold text-primary">@Model.TotalActiveUsers</div>
                <div class="text-muted small">bots enabled</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Open Positions</div>
                <div class="display-6 fw-bold text-info">@Model.TotalOpenPositions</div>
                <div class="text-muted small">across all users</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Aggregate Realized PnL</div>
                <div class="display-6 fw-bold @(Model.AggregateRealizedPnl >= 0 ? "text-success" : "text-danger")">
                    @(Model.AggregateRealizedPnl >= 0 ? "+" : "")@Model.AggregateRealizedPnl.ToString("F2") USDC
                </div>
                <div class="text-muted small">all users combined</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Aggregate Unrealized PnL</div>
                <div class="display-6 fw-bold @(Model.AggregateUnrealizedPnl >= 0 ? "text-success" : "text-danger")">
                    @(Model.AggregateUnrealizedPnl >= 0 ? "+" : "")@Model.AggregateUnrealizedPnl.ToString("F2") USDC
                </div>
                <div class="text-muted small">open positions</div>
            </div>
        </div>
    </div>
</div>

@* Per-User Summary Table *@
<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">User Activity</h5>
    </div>
    <div class="card-body p-0">
        @if (!Model.Users.Any())
        {
            <p class="text-muted p-3 mb-0">No users found.</p>
        }
        else
        {
            @* Mobile card view (< 576px) *@
            <div class="d-sm-none p-2">
                @foreach (var user in Model.Users)
                {
                    <div class="card mb-2 mobile-card">
                        <div class="card-body p-2">
                            <div class="d-flex justify-content-between">
                                <strong>@user.Email</strong>
                                @if (user.BotEnabled)
                                {
                                    <span class="badge bg-success">Enabled</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Disabled</span>
                                }
                            </div>
                            <div class="small">Positions: @user.OpenPositions | PnL: <span class="@(user.RealizedPnl >= 0 ? "text-success" : "text-danger")">@(user.RealizedPnl >= 0 ? "+" : "")@user.RealizedPnl.ToString("F2")</span></div>
                        </div>
                    </div>
                }
            </div>
            @* Desktop table view (>= 576px) *@
            <div class="table-responsive d-none d-sm-block">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Email</th>
                            <th>Bot Status</th>
                            <th class="text-end">Open Positions</th>
                            <th class="text-end">Realized PnL</th>
                            <th class="text-end">Configured Exchanges</th>
                            <th>Last Activity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>
                                    <span class="fw-medium">@user.Email</span>
                                </td>
                                <td>
                                    @if (user.BotEnabled)
                                    {
                                        <span class="badge bg-success">Enabled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Disabled</span>
                                    }
                                </td>
                                <td class="text-end">@user.OpenPositions</td>
                                <td class="text-end @(user.RealizedPnl >= 0 ? "text-success" : "text-danger")">
                                    @(user.RealizedPnl >= 0 ? "+" : "")@user.RealizedPnl.ToString("F2") USDC
                                </td>
                                <td class="text-end">@user.ConfiguredExchanges</td>
                                <td>
                                    @if (user.LastActivity.HasValue)
                                    {
                                        <span title="@user.LastActivity.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC">
                                            @user.LastActivity.Value.ToString("yyyy-MM-dd HH:mm") UTC
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No activity</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* Slippage Attribution (last 7 days) *@
<div class="card shadow-sm mt-4">
    <div class="card-header">
        <h5 class="mb-0">Slippage Attribution (7d)</h5>
    </div>
    <div class="card-body">
        @if (!Model.SlippageAttribution.ByPair.Any() && !Model.SlippageAttribution.ByAsset.Any())
        {
            <p class="text-muted mb-0">No closed positions in last 7 days.</p>
        }
        else
        {
            <div class="row g-3">
                <div class="col-lg-6">
                    <h6 class="text-muted">By Exchange Pair</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Pair</th>
                                    <th class="text-end">N</th>
                                    <th class="text-end" title="Average long-leg entry slippage">L Entry</th>
                                    <th class="text-end" title="Average short-leg entry slippage">S Entry</th>
                                    <th class="text-end" title="Average long-leg exit slippage">L Exit</th>
                                    <th class="text-end" title="Average short-leg exit slippage">S Exit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pair in Model.SlippageAttribution.ByPair)
                                {
                                    <tr>
                                        <td>@pair.LongExchangeName / @pair.ShortExchangeName</td>
                                        <td class="text-end">@pair.PositionCount</td>
                                        <td class="text-end">@(pair.AvgLongEntrySlippagePct.HasValue ? pair.AvgLongEntrySlippagePct.Value.ToString("P4") : "-")</td>
                                        <td class="text-end">@(pair.AvgShortEntrySlippagePct.HasValue ? pair.AvgShortEntrySlippagePct.Value.ToString("P4") : "-")</td>
                                        <td class="text-end">@(pair.AvgLongExitSlippagePct.HasValue ? pair.AvgLongExitSlippagePct.Value.ToString("P4") : "-")</td>
                                        <td class="text-end">@(pair.AvgShortExitSlippagePct.HasValue ? pair.AvgShortExitSlippagePct.Value.ToString("P4") : "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-lg-6">
                    <h6 class="text-muted">By Asset</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Asset</th>
                                    <th class="text-end">N</th>
                                    <th class="text-end" title="Average long-leg entry slippage">L Entry</th>
                                    <th class="text-end" title="Average short-leg entry slippage">S Entry</th>
                                    <th class="text-end" title="Average long-leg exit slippage">L Exit</th>
                                    <th class="text-end" title="Average short-leg exit slippage">S Exit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var asset in Model.SlippageAttribution.ByAsset)
                                {
                                    <tr>
                                        <td>@asset.AssetSymbol</td>
                                        <td class="text-end">@asset.PositionCount</td>
                                        <td class="text-end">@(asset.AvgLongEntrySlippagePct.HasValue ? asset.AvgLongEntrySlippagePct.Value.ToString("P4") : "-")</td>
                                        <td class="text-end">@(asset.AvgShortEntrySlippagePct.HasValue ? asset.AvgShortEntrySlippagePct.Value.ToString("P4") : "-")</td>
                                        <td class="text-end">@(asset.AvgLongExitSlippagePct.HasValue ? asset.AvgLongExitSlippagePct.Value.ToString("P4") : "-")</td>
                                        <td class="text-end">@(asset.AvgShortExitSlippagePct.HasValue ? asset.AvgShortExitSlippagePct.Value.ToString("P4") : "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
