@model IEnumerable<FundingRateArb.Domain.Entities.Exchange>
@{
    ViewData["Title"] = "Exchanges";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Exchanges</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Exchange
    </a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>API URL</th>
                    <th>WS URL</th>
                    <th>Funding Interval</th>
                    <th>Interval Hours</th>
                    <th>Sub-Accounts</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exchange in Model)
                {
                    <tr>
                        <td>@exchange.Name</td>
                        <td><span class="text-truncate d-inline-block" style="max-width:150px;" title="@exchange.ApiBaseUrl">@exchange.ApiBaseUrl</span></td>
                        <td><span class="text-truncate d-inline-block" style="max-width:150px;" title="@exchange.WsBaseUrl">@exchange.WsBaseUrl</span></td>
                        <td>@exchange.FundingInterval</td>
                        <td>@exchange.FundingIntervalHours</td>
                        <td>
                            @if (exchange.SupportsSubAccounts)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>
                            @if (exchange.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@exchange.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@exchange.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No exchanges configured yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
