@model ExchangeCreateViewModel
@{
    ViewData["Title"] = "Add Exchange";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Add Exchange</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FundingInterval" class="form-label"></label>
                    <select asp-for="FundingInterval" asp-items="Model.FundingIntervalOptions" class="form-select">
                        <option value="">-- Select Interval --</option>
                    </select>
                    <span asp-validation-for="FundingInterval" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ApiBaseUrl" class="form-label"></label>
                    <input asp-for="ApiBaseUrl" class="form-control" placeholder="https://api.example.com" />
                    <span asp-validation-for="ApiBaseUrl" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="WsBaseUrl" class="form-label"></label>
                    <input asp-for="WsBaseUrl" class="form-control" placeholder="wss://ws.example.com" />
                    <span asp-validation-for="WsBaseUrl" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="FundingIntervalHours" class="form-label"></label>
                    <input asp-for="FundingIntervalHours" class="form-control" type="number" min="1" max="24" />
                    <span asp-validation-for="FundingIntervalHours" class="text-danger"></span>
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="SupportsSubAccounts" class="form-check-input" type="checkbox" />
                        <label asp-for="SupportsSubAccounts" class="form-check-label"></label>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Create Exchange</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
