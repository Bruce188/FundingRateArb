@model FundingRateArb.Domain.Entities.Exchange
@{
    ViewData["Title"] = "Delete Exchange";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Delete Exchange</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card shadow-sm border-danger">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0">Confirm Deletion</h5>
    </div>
    <div class="card-body">
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }
        <p class="text-danger fw-bold">Are you sure you want to delete this exchange? This action cannot be undone.</p>

        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">API Base URL</dt>
            <dd class="col-sm-9">@Model.ApiBaseUrl</dd>

            <dt class="col-sm-3">WebSocket Base URL</dt>
            <dd class="col-sm-9">@Model.WsBaseUrl</dd>

            <dt class="col-sm-3">Funding Interval</dt>
            <dd class="col-sm-9">@Model.FundingInterval</dd>

            <dt class="col-sm-3">Active</dt>
            <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>
            }
        </dl>

        <form asp-action="Delete" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Delete Exchange</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
