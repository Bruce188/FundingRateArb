@model BotConfigViewModel
@using FundingRateArb.Domain.Enums
@using FundingRateArb.Application.Services
@{
    ViewData["Title"] = "Bot Configuration";
}

<h1 class="h3 mb-1">Bot Configuration</h1>
<p class="text-muted mb-3">
    These are global default values. Users can override them in their personal settings.
    Changes here affect the defaults for new users and the "Reset to Defaults" action.
</p>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Operating State Control (always visible, prominent) ── *@
@{
    var stateColor = Model.OperatingState switch
    {
        BotOperatingState.Stopped => "danger",
        BotOperatingState.Paused => "warning",
        BotOperatingState.Armed => "primary",
        BotOperatingState.Trading => "success",
        _ => "secondary"
    };
}
<div class="card mb-3 border-@stateColor shadow-sm">
    <div class="card-body d-flex justify-content-between align-items-center py-2">
        <div>
            <strong class="fs-5">Operating State</strong>
            <span class="badge bg-@stateColor fs-6 ms-2">@Model.OperatingState.ToString().ToUpperInvariant()</span>
        </div>
        <form asp-action="SetState" method="post" class="d-inline d-flex align-items-center gap-2">
            <select name="newState" class="form-select form-select-sm" style="width: auto;">
                @{
                    var states = new[] {
                        (Value: "Stopped", Label: "Stopped", Match: BotOperatingState.Stopped),
                        (Value: "Armed", Label: "Armed", Match: BotOperatingState.Armed),
                        (Value: "Paused", Label: "Paused", Match: BotOperatingState.Paused)
                    };
                }
                @foreach (var s in states)
                {
                    if (Model.OperatingState == s.Match)
                    {
                        <option value="@s.Value" selected="selected">@s.Label</option>
                    }
                    else
                    {
                        <option value="@s.Value">@s.Label</option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-sm btn-outline-@stateColor">Set State</button>
        </form>
    </div>
    <div class="card-footer bg-transparent py-1">
        <small class="text-muted">
            <strong>Stopped:</strong> monitoring only &middot;
            <strong>Armed:</strong> ready to trade &middot;
            <strong>Trading:</strong> auto (position open) &middot;
            <strong>Paused:</strong> emergency hold
        </small>
    </div>
</div>

@* ── Main configuration form ── *@
<form asp-action="Index" method="post">
    <input asp-for="IsEnabled" type="hidden" value="@(Model.OperatingState != BotOperatingState.Stopped)" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="accordion" id="configAccordion">

        @* ── Essential Defaults (always expanded) ── *@
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button"
                        data-bs-toggle="collapse" data-bs-target="#essentialDefaults">
                    Essential Defaults
                </button>
            </h2>
            <div id="essentialDefaults" class="accordion-collapse collapse show">
                <div class="accordion-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="TotalCapitalUsdc" class="form-label"></label>
                            <input asp-for="TotalCapitalUsdc" class="form-control" type="number" step="any" />
                            <span asp-validation-for="TotalCapitalUsdc" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="DefaultLeverage" class="form-label"></label>
                            <input asp-for="DefaultLeverage" class="form-control" type="number" min="1" max="50" />
                            <span asp-validation-for="DefaultLeverage" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="MaxConcurrentPositions" class="form-label"></label>
                            <input asp-for="MaxConcurrentPositions" class="form-control" type="number" min="1" max="10" />
                            <span asp-validation-for="MaxConcurrentPositions" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="MaxCapitalPerPosition" class="form-label"></label>
                            <input asp-for="MaxCapitalPerPosition" class="form-control" type="number" step="any" />
                            <div class="form-text">Fraction of total capital (0.01 - 1.0)</div>
                            <span asp-validation-for="MaxCapitalPerPosition" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Thresholds (always expanded) ── *@
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button"
                        data-bs-toggle="collapse" data-bs-target="#thresholds">
                    Thresholds
                </button>
            </h2>
            <div id="thresholds" class="accordion-collapse collapse show">
                <div class="accordion-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="OpenThreshold" class="form-label"></label>
                            <input asp-for="OpenThreshold" type="hidden" id="OpenThreshold_raw" />
                            <input type="number" step="0.001" class="form-control" id="OpenThreshold_pct" />
                            <div class="form-text">Minimum rate difference to open position (%/hr)</div>
                            <div class="form-text" id="OpenThreshold_minViable">
                                Min viable: <span id="OpenThreshold_minViable_pct">—</span>%/hr
                            </div>
                            <span asp-validation-for="OpenThreshold" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CloseThreshold" class="form-label"></label>
                            <input asp-for="CloseThreshold" type="hidden" id="CloseThreshold_raw" />
                            <input type="number" step="0.001" class="form-control" id="CloseThreshold_pct" />
                            <div class="form-text">Rate at which to close position (%/hr)</div>
                            <span asp-validation-for="CloseThreshold" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="AlertThreshold" class="form-label"></label>
                            <input asp-for="AlertThreshold" type="hidden" id="AlertThreshold_raw" />
                            <input type="number" step="0.001" class="form-control" id="AlertThreshold_pct" />
                            <div class="form-text">Rate at which to trigger alerts (%/hr)</div>
                            <span asp-validation-for="AlertThreshold" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EmergencyCloseSpreadThreshold" class="form-label"></label>
                            <input asp-for="EmergencyCloseSpreadThreshold" type="hidden" id="EmergencyCloseSpreadThreshold_raw" />
                            <input type="number" step="0.001" class="form-control" id="EmergencyCloseSpreadThreshold_pct" min="-100" max="0" />
                            <div class="form-text">Spread/hr below which SpreadCollapsed bypasses MinHoldTimeHours (%/hr)</div>
                            <span asp-validation-for="EmergencyCloseSpreadThreshold" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MinEdgeMultiplier" class="form-label"></label>
                            <input asp-for="MinEdgeMultiplier" class="form-control" type="number" step="any" min="0" max="20" />
                            <div class="form-text">Minimum net yield must exceed this multiple of amortized entry cost</div>
                            <span asp-validation-for="MinEdgeMultiplier" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DivergenceAlertMultiplier" class="form-label"></label>
                            <input asp-for="DivergenceAlertMultiplier" class="form-control" type="number" step="any" min="0.5" max="10" />
                            <div class="form-text">Alert when divergence exceeds this multiple of entry spread cost</div>
                            <span asp-validation-for="DivergenceAlertMultiplier" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DivergenceAlertConfirmationCycles" class="form-label"></label>
                            <input asp-for="DivergenceAlertConfirmationCycles" class="form-control" type="number" min="1" max="20" step="1" />
                            <div class="form-text">Consecutive cycles above threshold before alert fires (1 = immediate, 3 = production debounce)</div>
                            <span asp-validation-for="DivergenceAlertConfirmationCycles" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="RotationDivergenceHorizonHours" class="form-label"></label>
                            <input asp-for="RotationDivergenceHorizonHours" class="form-control" type="number" step="0.25" min="0.25" max="24" />
                            <div class="form-text">Hours over which new rotation opportunity must outperform divergence exit cost</div>
                            <span asp-validation-for="RotationDivergenceHorizonHours" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SlippageBufferBps" class="form-label"></label>
                            <input asp-for="SlippageBufferBps" class="form-control" type="number" min="0" max="50" />
                            <div class="form-text">Basis points subtracted from net yield for slippage</div>
                            <span asp-validation-for="SlippageBufferBps" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StablecoinAlertThresholdPct" class="form-label"></label>
                            <input asp-for="StablecoinAlertThresholdPct" class="form-control" type="number" step="any" min="0" max="5" />
                            <div class="form-text">USDT/USDC spread % at which to issue a warning alert</div>
                            <span asp-validation-for="StablecoinAlertThresholdPct" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StablecoinCriticalThresholdPct" class="form-label"></label>
                            <input asp-for="StablecoinCriticalThresholdPct" class="form-control" type="number" step="any" min="0" max="10" />
                            <div class="form-text">USDT/USDC spread % at which to close cross-stablecoin positions</div>
                            <span asp-validation-for="StablecoinCriticalThresholdPct" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MinConsecutiveFavorableCycles" class="form-label"></label>
                            <input asp-for="MinConsecutiveFavorableCycles" class="form-control" type="number" min="1" max="20" />
                            <div class="form-text">Consecutive positive-spread snapshots required before entry</div>
                            <span asp-validation-for="MinConsecutiveFavorableCycles" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FundingFlipExitCycles" class="form-label"></label>
                            <input asp-for="FundingFlipExitCycles" class="form-control" type="number" min="1" max="20" />
                            <div class="form-text">Consecutive negative-spread cycles before FundingFlipped close</div>
                            <span asp-validation-for="FundingFlipExitCycles" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Risk Management (collapsed by default) ── *@
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse" data-bs-target="#riskManagement">
                    Risk Management
                </button>
            </h2>
            <div id="riskManagement" class="accordion-collapse collapse">
                <div class="accordion-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="StopLossPct" class="form-label"></label>
                            <input asp-for="StopLossPct" class="form-control" type="number" step="any" />
                            <div class="form-text">Fraction (e.g. 0.15 = 15%)</div>
                            <span asp-validation-for="StopLossPct" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DailyDrawdownPausePct" class="form-label"></label>
                            <input asp-for="DailyDrawdownPausePct" class="form-control" type="number" step="any" min="0.01" max="1" />
                            <div class="form-text">Fraction of capital (e.g. 0.05 = 5%) -- pauses new opens when hit</div>
                            <span asp-validation-for="DailyDrawdownPausePct" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ConsecutiveLossPause" class="form-label"></label>
                            <input asp-for="ConsecutiveLossPause" class="form-control" type="number" min="1" max="20" />
                            <div class="form-text">Pause after N consecutive losing positions</div>
                            <span asp-validation-for="ConsecutiveLossPause" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxHoldTimeHours" class="form-label"></label>
                            <input asp-for="MaxHoldTimeHours" class="form-control" type="number" min="1" max="168" />
                            <span asp-validation-for="MaxHoldTimeHours" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MinHoldTimeHours" class="form-label"></label>
                            <input asp-for="MinHoldTimeHours" class="form-control" type="number" min="0" max="48" />
                            <div class="form-text">Minimum hours before SpreadCollapsed close (StopLoss always applies)</div>
                            <span asp-validation-for="MinHoldTimeHours" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxExposurePerAsset" class="form-label"></label>
                            <input asp-for="MaxExposurePerAsset" class="form-control" type="number" step="any" min="0.01" max="1" />
                            <div class="form-text">Max fraction of capital in any single asset (e.g. 0.5 = 50%)</div>
                            <span asp-validation-for="MaxExposurePerAsset" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxExposurePerExchange" class="form-label"></label>
                            <input asp-for="MaxExposurePerExchange" class="form-control" type="number" step="any" min="0.01" max="1" />
                            <div class="form-text">Max fraction of capital on any single exchange (e.g. 0.7 = 70%)</div>
                            <span asp-validation-for="MaxExposurePerExchange" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxLeverageCap" class="form-label"></label>
                            <input asp-for="MaxLeverageCap" class="form-control" type="number" min="1" max="50" />
                            <div class="form-text">Hard ceiling on leverage regardless of exchange limits</div>
                            <span asp-validation-for="MaxLeverageCap" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MarginUtilizationAlertPct" class="form-label"></label>
                            <input asp-for="MarginUtilizationAlertPct" class="form-control" type="number" step="any" min="0.1" max="0.95" />
                            <div class="form-text">Alert when margin utilization exceeds this fraction (e.g. 0.70 = 70%)</div>
                            <span asp-validation-for="MarginUtilizationAlertPct" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MinHoldBeforePnlTargetMinutes" class="form-label"></label>
                            <input asp-for="MinHoldBeforePnlTargetMinutes" class="form-control" type="number" min="0" max="1440" />
                            <div class="form-text">Minimum minutes before PnlTargetReached can fire</div>
                            <span asp-validation-for="MinHoldBeforePnlTargetMinutes" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LiquidationWarningPct" class="form-label"></label>
                            <input asp-for="LiquidationWarningPct" class="form-control" type="number" step="any" min="0.1" max="0.9" />
                            <div class="form-text">Fraction of safe range at which to close (0.5 = close when 50% consumed)</div>
                            <span asp-validation-for="LiquidationWarningPct" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LiquidationEarlyWarningPct" class="form-label"></label>
                            <input asp-for="LiquidationEarlyWarningPct" class="form-control" type="number" step="any" min="0.1" max="0.99" />
                            <div class="form-text">Alert threshold (must be higher than close threshold)</div>
                            <span asp-validation-for="LiquidationEarlyWarningPct" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ExchangeCircuitBreakerThreshold" class="form-label"></label>
                            <input asp-for="ExchangeCircuitBreakerThreshold" class="form-control" type="number" min="1" max="20" />
                            <div class="form-text">Consecutive failures before circuit breaker opens</div>
                            <span asp-validation-for="ExchangeCircuitBreakerThreshold" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ExchangeCircuitBreakerMinutes" class="form-label"></label>
                            <input asp-for="ExchangeCircuitBreakerMinutes" class="form-control" type="number" min="1" max="120" />
                            <div class="form-text">Minutes an exchange is excluded after circuit breaker opens</div>
                            <span asp-validation-for="ExchangeCircuitBreakerMinutes" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PriceFeedFailureCloseThreshold" class="form-label"></label>
                            <input asp-for="PriceFeedFailureCloseThreshold" class="form-control" type="number" min="5" max="100" />
                            <div class="form-text">Consecutive price feed failures before force-closing position</div>
                            <span asp-validation-for="PriceFeedFailureCloseThreshold" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Advanced (collapsed by default) ── *@
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse" data-bs-target="#advanced">
                    Advanced
                </button>
            </h2>
            <div id="advanced" class="accordion-collapse collapse">
                <div class="accordion-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="AllocationStrategy" class="form-label"></label>
                            <select asp-for="AllocationStrategy" class="form-select"
                                    asp-items="Html.GetEnumSelectList<AllocationStrategy>()"></select>
                            <div class="form-text">
                                Concentrated = all capital on best APR.
                                Spread modes distribute across top N opportunities.
                            </div>
                            <span asp-validation-for="AllocationStrategy" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="AllocationTopN" class="form-label"></label>
                            <input asp-for="AllocationTopN" class="form-control" type="number" min="1" max="20" />
                            <div class="form-text">Number of opportunities to spread capital across (ignored for Concentrated)</div>
                            <span asp-validation-for="AllocationTopN" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FeeAmortizationHours" class="form-label"></label>
                            <input asp-for="FeeAmortizationHours" class="form-control" type="number" min="1" max="168" />
                            <div class="form-text">Hours over which to amortize entry/exit fees</div>
                            <span asp-validation-for="FeeAmortizationHours" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MinPositionSizeUsdc" class="form-label"></label>
                            <input asp-for="MinPositionSizeUsdc" class="form-control" type="number" step="any" min="1" />
                            <div class="form-text">Minimum margin per position (exchange minimums)</div>
                            <span asp-validation-for="MinPositionSizeUsdc" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MinVolume24hUsdc" class="form-label"></label>
                            <input asp-for="MinVolume24hUsdc" class="form-control" type="number" step="any" min="0" />
                            <div class="form-text">Minimum 24h volume to consider an asset</div>
                            <span asp-validation-for="MinVolume24hUsdc" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="RateStalenessMinutes" class="form-label"></label>
                            <input asp-for="RateStalenessMinutes" class="form-control" type="number" min="1" max="120" />
                            <div class="form-text">Max age for funding rates before they are considered stale</div>
                            <span asp-validation-for="RateStalenessMinutes" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FundingWindowMinutes" class="form-label"></label>
                            <input asp-for="FundingWindowMinutes" class="form-control" type="number" min="1" max="60" />
                            <div class="form-text">Minutes before settlement to boost opportunity scoring</div>
                            <span asp-validation-for="FundingWindowMinutes" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TargetPnlMultiplier" class="form-label"></label>
                            <input asp-for="TargetPnlMultiplier" class="form-control" type="number" step="any" min="0.5" max="100" />
                            <div class="form-text">Close when accumulated funding &ge; this &times; entry fees</div>
                            <span asp-validation-for="TargetPnlMultiplier" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PnlTargetCooldownMinutes" class="form-label"></label>
                            <input asp-for="PnlTargetCooldownMinutes" class="form-control" type="number" min="5" max="1440" />
                            <div class="form-text">Minutes before a pair can be re-entered after hitting PnL target</div>
                            <span asp-validation-for="PnlTargetCooldownMinutes" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="AdaptiveHoldEnabled" class="form-check-input" type="checkbox" />
                                <label asp-for="AdaptiveHoldEnabled" class="form-check-label"></label>
                            </div>
                            <div class="form-text">Enable PnL-target exit (when off, only MaxHoldTimeHours applies)</div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="RebalanceEnabled" class="form-check-input" type="checkbox" />
                                <label asp-for="RebalanceEnabled" class="form-check-label"></label>
                            </div>
                            <div class="form-text">Enable automatic portfolio rebalancing</div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="RebalanceMinImprovement" class="form-label"></label>
                            <input asp-for="RebalanceMinImprovement" type="hidden" id="RebalanceMinImprovement_raw" />
                            <input type="number" step="0.001" class="form-control" id="RebalanceMinImprovement_pct" min="0" max="1" />
                            <div class="form-text">Minimum spread improvement to justify rebalance (%/hr)</div>
                            <span asp-validation-for="RebalanceMinImprovement" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxRebalancesPerCycle" class="form-label"></label>
                            <input asp-for="MaxRebalancesPerCycle" class="form-control" type="number" min="1" max="20" />
                            <div class="form-text">Max rebalance closes per bot cycle</div>
                            <span asp-validation-for="MaxRebalancesPerCycle" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="UseRiskBasedDivergenceClose" class="form-check-input" type="checkbox" />
                                <label asp-for="UseRiskBasedDivergenceClose" class="form-check-label"></label>
                            </div>
                            <div class="form-text text-warning">When enabled, DivergenceCritical close requires both MinHoldTime AND unhealthy liquidation distance. Disable to revert to immediate threshold-based close.</div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="PreferCloseOnDivergenceNarrowing" class="form-check-input" type="checkbox" />
                                <label asp-for="PreferCloseOnDivergenceNarrowing" class="form-check-label"></label>
                            </div>
                            <div class="form-text">When enabled, SpreadCollapsed close bypasses MinHoldTimeHours if divergence is narrowing. Soft-close preference for recovering positions.</div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="UseBreakEvenSizeFilter" class="form-check-input" type="checkbox" />
                                <label asp-for="UseBreakEvenSizeFilter" class="form-check-label"></label>
                            </div>
                            <div class="form-text text-warning">Stricter break-even filter rejects opportunities when net yield cannot cover MinEdgeMultiplier fees within MinHoldTime. Much more aggressive than the legacy edge guardrail.</div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="PairAutoDenyEnabled" class="form-check-input" type="checkbox" />
                                <label asp-for="PairAutoDenyEnabled" class="form-check-label"></label>
                            </div>
                            <div class="form-text">When enabled, pairs with zero wins across 10+ closed trades are automatically added to the deny list for 7 days.</div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="DryRunEnabled" class="form-check-input" type="checkbox" />
                                <label asp-for="DryRunEnabled" class="form-check-label"></label>
                            </div>
                            <div class="form-text text-warning">Paper trading mode. No real orders are placed on exchanges.</div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="ForceConcurrentExecution" class="form-check-input" type="checkbox" />
                                <label asp-for="ForceConcurrentExecution" class="form-check-label"></label>
                            </div>
                            <div class="form-text text-warning">Skip sequential execution and use Task.WhenAll for all exchanges. Risk: one-sided position on tx failure.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Infrastructure / Admin Only (collapsed by default) ── *@
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse" data-bs-target="#infrastructure">
                    Infrastructure (Admin Only)
                </button>
            </h2>
            <div id="infrastructure" class="accordion-collapse collapse">
                <div class="accordion-body">
                    <div class="alert alert-secondary py-2 mb-3">
                        These settings are not visible to users.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="VolumeFraction" class="form-label"></label>
                            <input asp-for="VolumeFraction" type="hidden" id="VolumeFraction_raw" />
                            <input type="number" step="0.001" class="form-control" id="VolumeFraction_pct" min="0.001" max="10" />
                            <div class="form-text">Max fraction of 24h volume per order (%)</div>
                            <span asp-validation-for="VolumeFraction" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BreakevenHoursMax" class="form-label"></label>
                            <input asp-for="BreakevenHoursMax" class="form-control" type="number" min="1" max="168" />
                            <div class="form-text">Max hours to break even on fees</div>
                            <span asp-validation-for="BreakevenHoursMax" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ReconciliationIntervalCycles" class="form-label"></label>
                            <input asp-for="ReconciliationIntervalCycles" class="form-control" type="number" min="1" max="100" />
                            <div class="form-text">Bot cycles between exchange position reconciliation checks</div>
                            <span asp-validation-for="ReconciliationIntervalCycles" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-3 mb-4">
        <button type="submit" class="btn btn-primary btn-lg">Save Configuration</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-forms.js"></script>
    <script>
        bindPercentInput('OpenThreshold_pct', 'OpenThreshold_raw', 100);
        bindPercentInput('CloseThreshold_pct', 'CloseThreshold_raw', 100);
        bindPercentInput('AlertThreshold_pct', 'AlertThreshold_raw', 100);
        bindPercentInput('EmergencyCloseSpreadThreshold_pct', 'EmergencyCloseSpreadThreshold_raw', 100);
        bindPercentInput('RebalanceMinImprovement_pct', 'RebalanceMinImprovement_raw', 100);
        bindPercentInput('VolumeFraction_pct', 'VolumeFraction_raw', 100);
    </script>
    <script>
        (function () {
            var feeRate = @ThresholdInvariantCalculator.EstimatedRoundTripFeeRate.ToString("0.0##", System.Globalization.CultureInfo.InvariantCulture);
            function recomputeOpenFloor() {
                var openInput = document.getElementById('OpenThreshold_pct');
                var openRaw = parseFloat(document.getElementById('OpenThreshold_raw').value);
                var closeRaw = parseFloat(document.getElementById('CloseThreshold_raw').value);
                var minHoldEl = document.getElementsByName('MinHoldTimeHours')[0];
                var minHold = minHoldEl ? parseFloat(minHoldEl.value) : NaN;
                if (!isFinite(openRaw) || !isFinite(closeRaw) || !isFinite(minHold) || minHold <= 0) {
                    document.getElementById('OpenThreshold_minViable_pct').textContent = '—';
                    return;
                }
                var floor = Math.abs(closeRaw) + feeRate / minHold;
                document.getElementById('OpenThreshold_minViable_pct').textContent = (floor * 100).toFixed(4);
                if (openRaw < floor) openInput.classList.add('is-invalid');
                else openInput.classList.remove('is-invalid');
            }
            ['OpenThreshold_pct', 'CloseThreshold_pct'].forEach(function (id) {
                var el = document.getElementById(id);
                if (el) el.addEventListener('blur', recomputeOpenFloor);
            });
            var minHoldEl = document.getElementsByName('MinHoldTimeHours')[0];
            if (minHoldEl) minHoldEl.addEventListener('blur', recomputeOpenFloor);
            document.addEventListener('DOMContentLoaded', recomputeOpenFloor);
            recomputeOpenFloor();
        })();
    </script>
}
